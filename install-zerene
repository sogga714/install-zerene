    echo "  > zram configured: ${ZRAM_SIZE_MB}MB zstd"
fi

# swapfile - only created when user picked swapfile or zram+swap
if [[ "$swap_choice" == "2" || "$swap_choice" == "3" ]]; then
    # create swapfile at the correct size
    echo "  > creating ${SWAP_SIZE_MB}MB swapfile..."
    dd if=/dev/zero of=/swapfile bs=1M count=${SWAP_SIZE_MB} status=progress
    chmod 600 /swapfile
    mkswap /swapfile
    swapon /swapfile
    # add swapfile to fstab so it persists on reboot
    echo "/swapfile none swap defaults 0 0" >> /etc/fstab
    echo "  > swapfile created and added to fstab"
fi

# hibernation - needs resume kernel param pointing at swap uuid or swapfile offset
if [[ "$HIBERNATION" == "true" && ("$swap_choice" == "2" || "$swap_choice" == "3") ]]; then
    # get the uuid of the root partition for resume= param
    SWAP_UUID=\$(findmnt -no UUID /swapfile 2>/dev/null || blkid -s UUID -o value "${TARGET_DISK}${P}2")
    # get the physical offset of the swapfile for resume_offset=
    SWAP_OFFSET=\$(filefrag -v /swapfile 2>/dev/null | awk '/^ *0:/{print \$4}' | tr -d '.')
    # append resume params to grub so kernel knows where to find swap on wake
    sed -i "s|GRUB_CMDLINE_LINUX_DEFAULT=\"|GRUB_CMDLINE_LINUX_DEFAULT=\"resume=UUID=\${SWAP_UUID} resume_offset=\${SWAP_OFFSET} |" /etc/default/grub
    # add resume hook to initramfs so it can restore state on boot
    sed -i 's/HOOKS=(.*filesystems/& resume/' /etc/mkinitcpio.conf
    mkinitcpio -P
    echo "  > hibernation configured (resume=UUID=\${SWAP_UUID} offset=\${SWAP_OFFSET})"
elif [[ "$HIBERNATION" == "true" && "$swap_choice" == "1" ]]; then
    # zram-only hibernation path - uses systemd-hibernate-resume with zram
    # note: zram hibernation requires kernel 6.1+ and CONFIG_HIBERNATION_ZRAM
    echo "  > zram hibernation requested - enabling systemd hibernate target"
    systemctl enable systemd-hibernate.target 2>/dev/null || true
fi

