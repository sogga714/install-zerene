#!/bin/bash

# zerene os installer - xenovia 1


BLUE='\033[38;2;5;4;216m'       # #0504D8 zerene blue
LBLUE='\033[38;2;100;110;255m'  # lighter blue for accents
WHITE='\033[1;37m'
GRAY='\033[38;2;160;160;180m'
DIM='\033[2m'
BOLD='\033[1m'
RED='\033[0;31m'
GREEN='\033[0;32m'
RESET='\033[0m'

# draw a horizontal rule
rule() { echo -e "${BLUE}$(printf '─%.0s' $(seq 1 60))${RESET}"; }

# section header like archinstall but zerene style
header() {
    echo
    rule
    echo -e "${BLUE}${BOLD}  $1${RESET}"
    rule
    echo
}

# status messages
msg()  { echo -e "${BLUE}  ›${RESET} $1"; }
ok()   { echo -e "${GREEN}  ✓${RESET} $1"; }
warn() { echo -e "${RED}  !${RESET} $1"; }
err()  { echo -e "${RED}  ERROR:${RESET} $1"; exit 1; }

# step label printed before running something visible
step() { echo -e "\n${BLUE}${BOLD}  ──  $1  ──${RESET}\n"; }

SPIN_PID=""

spin_start() {
    local label="${1:-working...}"
    local blades=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    local outer=('◢◤' '◥◣' '◤◢' '◣◥')
    (
        local i=0 b=0
        while true; do
            printf "\r${BLUE}  %s %s${RESET}  ${GRAY}%s${RESET}    " \
                "${blades[$b]}" "${outer[$i]}" "$label"
            sleep 0.07
            i=$(( (i+1) % 4 ))
            b=$(( (b+1) % 8 ))
        done
    ) &
    SPIN_PID=$!
}

spin_stop() {
    [[ -n "$SPIN_PID" ]] && kill "$SPIN_PID" 2>/dev/null && wait "$SPIN_PID" 2>/dev/null
    SPIN_PID=""
    printf "\r%-70s\r" " "
}

trap spin_stop EXIT

# --------------------------------------------------------
# whiptail wrappers - themed to zerene blue via NEWT_COLORS
# --------------------------------------------------------

# whiptail reads NEWT_COLORS to theme its dialogs
# root=blue bg, window=dark, title=bright blue, button=blue
export NEWT_COLORS='
root=,black
window=white,black
shadow=black,black
border=blue,black
title=brightblue,black
roottext=white,black
listbox=white,black
actlistbox=black,brightblue
sellistbox=black,brightblue
actsellistbox=black,brightblue
textbox=white,black
acttextbox=black,brightblue
button=black,brightblue
actbutton=white,blue
compactbutton=white,black
checkbox=white,black
actcheckbox=black,brightblue
entry=white,black
disentry=gray,black
label=brightblue,black
emptyscale=,black
fullscale=brightblue,black
helpline=black,brightblue
'

tui_menu() {
    local title="$1" prompt="$2"; shift 2
    whiptail --title "  $title  " --menu "$prompt" 22 72 14 "$@" 3>&1 1>&2 2>&3
}

tui_yesno() {
    whiptail --title "  $1  " --yesno "$2" 10 62
}

tui_input() {
    local title="$1" prompt="$2" default="${3:-}"
    whiptail --title "  $title  " --inputbox "$prompt" 10 62 "$default" 3>&1 1>&2 2>&3
}

tui_pass() {
    whiptail --title "  $1  " --passwordbox "$2" 10 62 3>&1 1>&2 2>&3
}

tui_msg() {
    whiptail --title "  $1  " --msgbox "$2" 12 62
}

# --------------------------------------------------------
# splash
# --------------------------------------------------------

clear
echo
echo -e "${BLUE}${BOLD}"
cat << 'LOGO'
    ███████╗███████╗██████╗ ███████╗███╗   ██╗███████╗
    ╚══███╔╝██╔════╝██╔══██╗██╔════╝████╗  ██║██╔════╝
      ███╔╝ █████╗  ██████╔╝█████╗  ██╔██╗ ██║█████╗
     ███╔╝  ██╔══╝  ██╔══██╗██╔══╝  ██║╚██╗██║██╔══╝
    ███████╗███████╗██║  ██║███████╗██║ ╚████║███████╗
    ╚══════╝╚══════╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═══╝╚══════╝
LOGO
echo -e "${RESET}"
echo -e "${GRAY}                  xenovia 1  ·  installer${RESET}"
echo
rule
echo

# check whiptail
if ! command -v whiptail &>/dev/null; then
    msg "installing whiptail..."
    pacman -S --noconfirm libnewt &>/dev/null
fi

# internet check
msg "checking internet..."
if ! ping -c 1 -W 3 google.com &>/dev/null; then
    tui_msg "No Internet" "No internet connection detected.\n\nOpening nmtui — connect to your network then re-run the installer."
    nmtui
    ping -c 1 -W 3 google.com &>/dev/null || err "no internet, cannot continue"
fi
ok "connected"
echo

# --------------------------------------------------------
# hardware scan
# --------------------------------------------------------

spin_start "scanning hardware"
CPU_VENDOR=$(grep -m1 "vendor_id" /proc/cpuinfo | awk '{print $3}')
CPU_MODEL_NAME=$(grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | xargs)
CPU_CORES=$(nproc)
CPU_FAMILY=$(grep -m1 "cpu family" /proc/cpuinfo | awk '{print $4}')
CPU_MODEL=$(grep -m1 "^model[[:space:]]" /proc/cpuinfo | awk '{print $3}')
RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
RAM_HALF=$(( RAM_MB / 2 ))
IS_LAPTOP=false
IS_VM=false
DISK_TYPE="hdd"
SWAPPINESS=10

[ -d /sys/class/power_supply/BAT0 ] || [ -d /sys/class/power_supply/BAT1 ] && IS_LAPTOP=true
grep -qi "virtualbox\|vmware\|kvm\|qemu\|hyper-v" /sys/class/dmi/id/product_name 2>/dev/null && IS_VM=true

CPU_GEN=0
if [[ "$CPU_VENDOR" == "GenuineIntel" ]]; then
    CPU_GEN=$(grep -m1 "model name" /proc/cpuinfo | grep -oP "\d+(?:st|nd|rd|th) Gen" | grep -oP "^\d+" || echo 0)
fi
spin_stop

ok "hardware scanned: ${CPU_MODEL_NAME} · ${CPU_CORES} cores · ${RAM_MB}MB RAM"
echo

# --------------------------------------------------------
# configuration - all questions before anything installs
# --------------------------------------------------------

header "System Identity"

hostname=$(tui_input "Hostname" "Enter a hostname for this machine:" "zerene") || err "cancelled"
username=$(tui_input "User Account" "Enter your username:") || err "cancelled"
password=$(tui_pass "User Account" "Enter password:") || err "cancelled"
password2=$(tui_pass "User Account" "Confirm password:") || err "cancelled"
[[ "$password" != "$password2" ]] && err "passwords do not match"

header "Disk"

DISK_LIST=()
while IFS= read -r line; do
    name=$(echo "$line" | awk '{print $1}')
    size=$(echo "$line" | awk '{print $2}')
    model=$(echo "$line" | awk '{$1=$2=""; print $0}' | xargs)
    DISK_LIST+=("$name" "$size  $model")
done < <(lsblk -dno NAME,SIZE,MODEL | grep -v "loop")

DISK_ID=$(tui_menu "Disk Selection" "Select the disk to install Zerene OS on:" "${DISK_LIST[@]}") || err "cancelled"
TARGET_DISK="/dev/$DISK_ID"
[[ $TARGET_DISK == *"nvme"* ]] && P="p" || P=""

if [[ "$TARGET_DISK" == *"nvme"* ]]; then
    DISK_TYPE="nvme"
elif [[ "$(cat /sys/block/$(basename $TARGET_DISK)/queue/rotational 2>/dev/null)" == "0" ]]; then
    DISK_TYPE="ssd"
fi

if [[ "$DISK_TYPE" == "nvme" ]]; then
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="nvme[0-9]*", ATTR{queue/scheduler}="none"'
elif [[ "$DISK_TYPE" == "ssd" ]]; then
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="mq-deadline"'
else
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"'
fi

tui_yesno "Format Disk" "Wipe and format $TARGET_DISK ?\n\nThis will erase ALL data on this disk." \
    && FORMAT_DISK=true || FORMAT_DISK=false

header "Nix Package Manager"

nix_choice=$(tui_menu "Nix" "Include Nix package manager?" \
    "1" "Yes - install Nix (multi-user daemon mode)" \
    "2" "No  - skip Nix") || err "cancelled"

header "Kernel"

KERN_PROMPT="  CPU:    $CPU_MODEL_NAME\n  Cores:  $CPU_CORES     RAM: ${RAM_MB} MB\n  Disk:   $DISK_TYPE     Laptop: $IS_LAPTOP\n\nSelect a kernel:"

kernel_choice=$(tui_menu "Kernel" "$KERN_PROMPT" \
    "1" "linux          - stable, default arch kernel" \
    "2" "linux-zen      - lower latency, better for gaming/desktop" \
    "3" "linux-hardened - security hardened" \
    "4" "auto-tune      - zerene picks best kernel + tunes for your hw" \
    "5" "advanced       - you configure it (menuconfig / vim / nano)") || err "cancelled"

KERNEL_PKG="linux"
KERNEL_HEADERS="linux-headers"
ADVANCED_KERNEL=false
AUTO_TUNE=false
KERN_PARAMS=""

case "$kernel_choice" in
    1) KERNEL_PKG="linux";          KERNEL_HEADERS="linux-headers" ;;
    2) KERNEL_PKG="linux-zen";      KERNEL_HEADERS="linux-zen-headers" ;;
    3) KERNEL_PKG="linux-hardened"; KERNEL_HEADERS="linux-hardened-headers" ;;
    4)
        AUTO_TUNE=true
        if   [[ "$IS_VM" == "true" ]]; then
            KERNEL_PKG="linux";     KERNEL_HEADERS="linux-headers"
        elif [[ "$CPU_VENDOR" == "AuthenticAMD" && "$IS_LAPTOP" == "false" ]]; then
            KERNEL_PKG="linux-zen"; KERNEL_HEADERS="linux-zen-headers"
        else
            KERNEL_PKG="linux";     KERNEL_HEADERS="linux-headers"
        fi
        # amd tuning
        if [[ "$CPU_VENDOR" == "AuthenticAMD" ]]; then
            if [[ "$CPU_FAMILY" -ge 25 ]] || { [[ "$CPU_FAMILY" -eq 23 ]] && [[ "$CPU_MODEL" -ge 49 ]]; }; then
                KERN_PARAMS="$KERN_PARAMS amd_pstate=active"
            fi
            KERN_PARAMS="$KERN_PARAMS processor.max_cstate=5"
            [[ "$IS_VM" == "false" ]] && KERN_PARAMS="$KERN_PARAMS spec_store_bypass_disable=prctl spectre_v2=off"
        fi
        # intel tuning
        [[ "$CPU_VENDOR" == "GenuineIntel" && "$CPU_GEN" -ge 6 ]] && KERN_PARAMS="$KERN_PARAMS intel_pstate=active"
        # laptop extras
        [[ "$IS_LAPTOP" == "true" ]] && KERN_PARAMS="$KERN_PARAMS pcie_aspm=force nmi_watchdog=0"
        [[ "$RAM_MB" -lt 4096 ]] && SWAPPINESS=30 || SWAPPINESS=10
        ;;
    5)
        ADVANCED_KERNEL=true
        KERNEL_PKG="linux"; KERNEL_HEADERS="linux-headers"
        kconfig_method=$(tui_menu "Kernel Config" "Choose your config method:" \
            "1" "menuconfig - ncurses TUI" \
            "2" "xconfig    - Qt GUI (needs X)" \
            "3" "vim        - edit .config in vim" \
            "4" "nano       - edit .config in nano") || err "cancelled"
        ;;
esac

header "System"

kbd_choice=$(tui_menu "Keyboard Layout" "Select keyboard layout:" \
    "us" "QWERTY  (US)" \
    "fr" "AZERTY  (FR)") || err "cancelled"
LAYOUT="$kbd_choice"

audio_choice=$(tui_menu "Audio" "Select audio system:" \
    "1" "Pipewire   - modern, recommended" \
    "2" "Pulseaudio - classic") || err "cancelled"

header "Desktop Environment"

desktop_choice=$(tui_menu "Desktop Environment" "Select your desktop environment:" \
    "1"  "Hyprland    wayland tiling compositor" \
    "2"  "KDE Plasma  full featured kde desktop" \
    "3"  "XFCE4       lightweight classic desktop" \
    "4"  "GNOME       clean modern desktop" \
    "5"  "Sway        wayland tiling, minimal" \
    "6"  "i3          x11 tiling, very lightweight" \
    "7"  "Cinnamon    traditional, based on gnome" \
    "8"  "MATE        classic gnome 2 fork" \
    "9"  "LXQt        super lightweight qt desktop" \
    "10" "Budgie      clean and simple" \
    "11" "Deepin      polished desktop env" \
    "12" "Openbox     bare window manager only" \
    "13" "bspwm       tiling wm, scriptable" \
    "14" "Qtile       python tiling wm" \
    "15" "COSMIC      new rust desktop from system76" \
    "16" "None        no desktop") || err "cancelled"

header "AUR Helper"

aur_helper=$(tui_menu "AUR Helper" "Select AUR helper to install:" \
    "1" "yay   - go based, most popular" \
    "2" "paru  - rust based, faster" \
    "3" "none  - skip") || err "cancelled"

header "GPU Driver"

gpu_choice=$(tui_menu "GPU Driver" "Select GPU driver:" \
    "1" "NVIDIA Modern   RTX / Turing, GTX 1650 and newer" \
    "2" "NVIDIA Legacy   Pascal GTX 10xx and older  (AUR)" \
    "3" "AMD             mesa + vulkan-radeon, RDNA/GCN" \
    "4" "Intel           integrated graphics" \
    "5" "VM / None       virtual machine or skip") || err "cancelled"

header "Network"

net_choice=$(tui_menu "Network Manager" "Select network manager:" \
    "1" "NetworkManager  full featured, nmtui/nmcli support" \
    "2" "iwd (iwctl)     lightweight, fast, WPA3") || err "cancelled"

NET_PKG="networkmanager"
[[ "$net_choice" == "2" ]] && NET_PKG="iwd dhcpcd"

# --------------------------------------------------------
# readable names for summary
# --------------------------------------------------------

case $desktop_choice in
    1) DN="Hyprland" ;;  2) DN="KDE Plasma" ;; 3) DN="XFCE4" ;;
    4) DN="GNOME" ;;     5) DN="Sway" ;;        6) DN="i3" ;;
    7) DN="Cinnamon" ;;  8) DN="MATE" ;;         9) DN="LXQt" ;;
    10) DN="Budgie" ;;   11) DN="Deepin" ;;      12) DN="Openbox" ;;
    13) DN="bspwm" ;;    14) DN="Qtile" ;;       15) DN="COSMIC" ;;
    *) DN="None" ;;
esac
case $aur_helper in 1) AN="yay" ;; 2) AN="paru" ;; *) AN="none" ;; esac
case $gpu_choice in
    1) GN="NVIDIA Modern" ;; 2) GN="NVIDIA Legacy" ;;
    3) GN="AMD" ;;           4) GN="Intel" ;; 5) GN="VM/None" ;;
esac
case $net_choice in 1) NN="NetworkManager" ;; 2) NN="iwd" ;; esac
case $nix_choice in 1) NIXN="yes" ;; *) NIXN="no" ;; esac
case $audio_choice in 1) AUDN="Pipewire" ;; 2) AUDN="Pulseaudio" ;; esac

# --------------------------------------------------------
# confirm summary
# --------------------------------------------------------

SUM="
  Hostname   $hostname
  User       $username
  Disk       $TARGET_DISK   (format: $FORMAT_DISK)

  Kernel     $KERNEL_PKG
  Headers    $KERNEL_HEADERS
  Auto-tune  $AUTO_TUNE

  Layout     $LAYOUT
  Audio      $AUDN
  Desktop    $DN
  AUR        $AN
  GPU        $GN
  Network    $NN
  Nix        $NIXN

Press Enter to begin installation, Esc to cancel."

tui_yesno "Confirm Installation" "$SUM" || err "cancelled"

# --------------------------------------------------------
# installation - output is visible from here on
# --------------------------------------------------------

clear
echo
echo -e "${BLUE}${BOLD}    zerene os  ·  installing...${RESET}"
echo
rule
echo

# partition
if [[ "$FORMAT_DISK" == "true" ]]; then
    step "Partitioning $TARGET_DISK"
    swapoff -a
    parted -s "$TARGET_DISK" mklabel gpt
    parted -s "$TARGET_DISK" mkpart ESP fat32 1MiB 513MiB
    parted -s "$TARGET_DISK" set 1 esp on
    parted -s "$TARGET_DISK" mkpart primary ext4 513MiB 100%
    mkfs.fat -F32 "${TARGET_DISK}${P}1"
    mkfs.ext4 -F "${TARGET_DISK}${P}2"
    ok "partitioned"
fi

step "Mounting"
mount "${TARGET_DISK}${P}2" /mnt
mkdir -p /mnt/boot/efi
mount "${TARGET_DISK}${P}1" /mnt/boot/efi
ok "mounted"

INSTALL_NIX=false
if [[ "$nix_choice" == "1" ]]; then
    INSTALL_NIX=true
    mkdir -p /mnt/nix/{store,var/nix/db,var/nix/profiles,var/nix/channel-cache}
    chmod -R 1775 /mnt/nix/store
    mkdir -p /mnt/var/empty
fi

step "Installing Base System  ($KERNEL_PKG + $KERNEL_HEADERS)"
pacstrap /mnt base "$KERNEL_PKG" "$KERNEL_HEADERS" linux-firmware \
    sudo fastfetch plymouth $NET_PKG base-devel dosfstools git dkms

ok "base installed"

# advanced kernel
if [[ "$ADVANCED_KERNEL" == "true" ]]; then
    step "Kernel Source Build"
    arch-chroot /mnt bash <<KCONF
        pacman -S --noconfirm asp base-devel
        mkdir -p /root/kernelbuild && cd /root/kernelbuild
        asp export linux && cd linux
        zcat /proc/config.gz > .config 2>/dev/null || \
            cp /usr/lib/modules/\$(uname -r)/build/.config .config 2>/dev/null || \
            make defconfig
        case "$kconfig_method" in
            1) pacman -S --noconfirm ncurses; make menuconfig ;;
            2) pacman -S --noconfirm qt5-base; make xconfig ;;
            3) pacman -S --noconfirm vim; vim .config ;;
            4) pacman -S --noconfirm nano; nano .config ;;
        esac
        read -rp "Build and install kernel now? [Y/n]: " b
        if [[ ! "\$b" =~ ^[Nn]$ ]]; then
            make -j\$(nproc)
            make modules_install
            make install
        fi
KCONF
fi

step "Copying Zerene Assets"
mkdir -p /mnt/etc/fastfetch
[ -d /etc/fastfetch ] && cp -r /etc/fastfetch/* /mnt/etc/fastfetch/
mkdir -p /mnt/usr/share/pixmaps
cp /usr/share/pixmaps/zerene.svg /mnt/usr/share/pixmaps/ 2>/dev/null || true
mkdir -p /mnt/usr/share/plymouth/themes/
cp -r /usr/share/plymouth/themes/zerene-spinner /mnt/usr/share/plymouth/themes/ 2>/dev/null || true
ok "assets copied"

# --------------------------------------------------------
# chroot
# --------------------------------------------------------

step "Entering Chroot"

arch-chroot /mnt bash <<EOF

echo "$hostname" > /etc/hostname
echo "KEYMAP=$LAYOUT" > /etc/vconsole.conf

mkdir -p /etc/X11/xorg.conf.d
cat > /etc/X11/xorg.conf.d/00-keyboard.conf <<XKEYBOARD
Section "InputClass"
    Identifier "system-keyboard"
    MatchIsKeyboard "on"
    Option "XkbLayout" "$LAYOUT"
EndSection
XKEYBOARD

cat > /etc/os-release <<OS
NAME="Zerene OS"
PRETTY_NAME="Zerene OS (Xenovia 1)"
ID=zerene
ID_LIKE=arch
ANSI_COLOR="38;2;5;4;216"
LOGO=zerene
OS
echo 'GRUB_DISTRIBUTOR="Zerene OS"' >> /etc/default/grub

echo ""
echo -e "\033[38;2;5;4;216m  ──  Users & Groups  ──\033[0m"
echo ""
groupadd -r -g 970 nixbld 2>/dev/null || true
groupadd -r nix-users 2>/dev/null || true
for n in \$(seq -w 01 10); do
    useradd -r -u 97\$n -g nixbld -G nixbld -d /var/empty -s /sbin/nologin nixbld\$n 2>/dev/null || true
done
useradd -m -G wheel,video,audio,storage,nix-users -s /bin/bash "$username" 2>/dev/null || true
echo "$username:$password" | chpasswd
echo "root:$password" | chpasswd

if [ ! -f /etc/sudoers ]; then touch /etc/sudoers; chmod 440 /etc/sudoers; fi
if ! grep -q "^%wheel" /etc/sudoers; then echo "%wheel ALL=(ALL:ALL) ALL" >> /etc/sudoers; fi
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers
echo "  > users configured"

# nix
if [[ "$INSTALL_NIX" == "true" ]]; then
    pacman -S --noconfirm nix
    mkdir -p /nix/{store,var/nix/db,var/nix/profiles,var/nix/channel-cache}
    chown -R root:nixbld /nix/store
    chmod 1775 /nix/store
    chown -R root:nixbld /nix/var/nix
    chmod -R ug+rwX /nix/var/nix
    
    mkdir -p /etc/nix
    cat > /etc/nix/nix.conf <<NIX
experimental-features = nix-command 
max-jobs = auto
build-users-group = nixbld
# CRITICAL: Disable sandboxing for the chroot install phase
sandbox = false
NIX
    
    systemctl enable nix-daemon
    
    # Exporting this prevents nix-channel from trying to talk to a daemon that isn't running yet
    export NIX_REMOTE=""
    nix-channel --add https://nixos.org/channels/nixpkgs-unstable nixpkgs
    nix-channel --update || echo "Channel update failed (expected in chroot), will finish on reboot."
fi

# fastfetch
mkdir -p /home/$username/.config/fastfetch
cat > /home/$username/.config/fastfetch/config.jsonc <<FF
{
  "logo": {
    "source": "/etc/fastfetch/zerene-ascii.txt",
    "color": { "1":"blue","2":"blue","3":"blue","4":"blue","5":"blue","6":"blue","7":"blue","8":"blue","9":"blue" }
  },
  "modules": [
    { "type":"os","keyColor":"blue","valueColor":"blue" },
    { "type":"kernel","keyColor":"blue","valueColor":"blue" },
    { "type":"uptime","keyColor":"blue","valueColor":"blue" },
    { "type":"memory","keyColor":"blue","valueColor":"blue" },
    { "type":"cpu","keyColor":"blue","valueColor":"blue" },
    { "type":"gpu","keyColor":"blue","valueColor":"blue" },
    { "type":"shell","keyColor":"blue","valueColor":"blue" },
    { "type":"wm","keyColor":"blue","valueColor":"blue" },
    { "type":"de","keyColor":"blue","valueColor":"blue" },
    { "type":"disk","keyColor":"blue","valueColor":"blue" },
    { "type":"packages","keyColor":"blue","valueColor":"blue" }
  ]
}
FF
echo "fastfetch" >> /home/$username/.bashrc
chown -R $username:$username /home/$username

echo ""
echo -e "\033[38;2;5;4;216m  ──  Audio  ──\033[0m"
echo ""
if [ "$audio_choice" == "1" ]; then
    pacman -S --noconfirm pipewire pipewire-pulse wireplumber
else
    pacman -S --noconfirm pulseaudio
fi

echo ""
echo -e "\033[38;2;5;4;216m  ──  GPU Drivers  ──\033[0m"
echo ""
case "$gpu_choice" in
    1)
        # nvidia modern - rtx/turing/4060 etc
        # install nvidia-dkms, utils, settings
        pacman -S --noconfirm nvidia-dkms nvidia-utils nvidia-settings \
            lib32-nvidia-utils libglvnd lib32-libglvnd opencl-nvidia

        # dkms builds the module for the installed kernel
        echo "  > running dkms autoinstall..."
        dkms autoinstall

        # add nvidia modules to initramfs before rebuild
        sed -i 's/^MODULES=(/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf

        # kms hook conflicts with nvidia early loading - causes black screen on wayland
        sed -i 's/ kms//' /etc/mkinitcpio.conf

        # rebuild initramfs with the nvidia modules in it
        echo "  > rebuilding initramfs..."
        mkinitcpio -P

        # blacklist nouveau so it cant load and fight nvidia
        echo "blacklist nouveau" > /etc/modprobe.d/blacklist-nouveau.conf
        echo "options nouveau modeset=0" >> /etc/modprobe.d/blacklist-nouveau.conf

        # pacman hook - auto rebuilds initramfs whenever nvidia-dkms updates
        mkdir -p /etc/pacman.d/hooks
        cat > /etc/pacman.d/hooks/nvidia.hook <<NVHOOK
[Trigger]
Operation=Install
Operation=Upgrade
Operation=Remove
Type=Package
Target=nvidia-dkms

[Action]
Description=Updating initramfs after nvidia update...
When=PostTransaction
Exec=/usr/bin/mkinitcpio -P
NVHOOK
        ;;
    2)
        # nvidia legacy - pascal gtx 10xx and older, aur only since driver 590
        pacman -S --noconfirm git base-devel
        cd /tmp
        git clone https://aur.archlinux.org/nvidia-580xx-dkms.git
        chown -R "$username:$username" /tmp/nvidia-580xx-dkms
        cd /tmp/nvidia-580xx-dkms
        sudo -u "$username" makepkg -si --noconfirm
        cd /
        pacman -S --noconfirm nvidia-utils lib32-nvidia-utils libglvnd lib32-libglvnd
        dkms autoinstall
        sed -i 's/^MODULES=(/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf
        sed -i 's/ kms//' /etc/mkinitcpio.conf
        mkinitcpio -P
        echo "blacklist nouveau" > /etc/modprobe.d/blacklist-nouveau.conf
        echo "options nouveau modeset=0" >> /etc/modprobe.d/blacklist-nouveau.conf
        ;;
    3)
        pacman -S --noconfirm mesa lib32-mesa vulkan-radeon lib32-vulkan-radeon \
            xf86-video-amdgpu libva-mesa-driver lib32-libva-mesa-driver \
            vulkan-icd-loader lib32-vulkan-icd-loader
        ;;
    4)
        pacman -S --noconfirm mesa lib32-mesa vulkan-intel lib32-vulkan-intel \
            intel-media-driver libva-utils vulkan-icd-loader lib32-vulkan-icd-loader
        ;;
    5)
        pacman -S --noconfirm mesa lib32-mesa
        ;;
esac

