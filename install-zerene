step_disk() {
    DISK_LIST=()
    while IFS= read -r line; do
        local name size model
        name=$(echo "$line" | awk '{print $1}')
        size=$(echo "$line" | awk '{print $2}')
        model=$(echo "$line" | awk '{$1=$2=""; print $0}' | xargs)
        DISK_LIST+=("$name" "${size}  ${model}")
    done < <(lsblk -dno NAME,SIZE,MODEL | grep -v "loop")

    local did
    did=$(tui_menu "Disk Selection" "Select the disk to install Zerene OS on:" "${DISK_LIST[@]}") || return 1
    DISK_ID="$did"
    TARGET_DISK="/dev/$DISK_ID"
    [[ $TARGET_DISK == *"nvme"* ]] && P="p" || P=""

    if [[ "$TARGET_DISK" == *"nvme"* ]]; then
        DISK_TYPE="nvme"
    elif [[ "$(cat /sys/block/$(basename $TARGET_DISK)/queue/rotational 2>/dev/null)" == "0" ]]; then
        DISK_TYPE="ssd"
    else
        DISK_TYPE="hdd"
    fi

    if [[ "$DISK_TYPE" == "nvme" ]]; then
        IO_SCHED_RULE='ACTION=="add|change", KERNEL=="nvme[0-9]*", ATTR{queue/scheduler}="none"'
    elif [[ "$DISK_TYPE" == "ssd" ]]; then
        IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="mq-deadline"'
    else
        IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"'
    fi

    TOTAL_DISK_SIZE=$(lsblk -dno SIZE -b "$TARGET_DISK" | awk '{printf "%.0f", $1/1024/1024/1024}')
}

step_disk_option() {
    # detect existing partitions and free space
    local existing_parts
    existing_parts=$(list_existing_partitions "$TARGET_DISK")
    local detected_free_gb
    detected_free_gb=$(detect_free_space "$TARGET_DISK" "$TOTAL_DISK_SIZE")

    local part_info=""
    if [[ -n "$existing_parts" ]]; then
        part_info="\nExisting partitions:\n$existing_parts\n\nLargest free region: ~${detected_free_gb}GB"
    else
        part_info="\nNo existing partitions detected - disk appears empty."
    fi

    local doc
    doc=$(tui_radiolist "Disk Option" \
        "Disk: ${TARGET_DISK} (${TOTAL_DISK_SIZE}GB)${part_info}\n\nSelect installation method:" \
        "1" "Format entire disk  - erase everything, single OS" $([ "$disk_option_choice" == "1" ] && echo ON || echo OFF) \
        "2" "Split disk          - dual boot, use free space"    $([ "$disk_option_choice" == "2" ] && echo ON || echo OFF)) || return 1
    disk_option_choice="$doc"

    case "$disk_option_choice" in
        1)
            FORMAT_DISK=true
            SPLIT_DISK=false
            SPLIT_PERCENT=100
            FREE_DISK_SPACE=$TOTAL_DISK_SIZE

            tui_yesno "Format Disk" "Wipe and format $TARGET_DISK ?\n\nThis will ERASE ALL DATA on this disk.\nMake sure you have backups." \
                && FORMAT_DISK=true || { disk_option_choice=""; step_disk_option; return $?; }
            ;;
        2)
            FORMAT_DISK=false
            SPLIT_DISK=true

            # ── accurate split slider ──────────────────────────────────────
            # build slider options from 10GB up to detected_free_gb in steps
            local SLIDER_ITEMS=()
            local step_gb=5
            local min_gb=10
            local g

            # if free space < 10GB warn
            if [[ "$detected_free_gb" -lt 10 ]]; then
                tui_msg "Low Free Space" \
                    "Only ~${detected_free_gb}GB of free space detected on $TARGET_DISK.\n\nZerene OS needs at least 10GB. Consider freeing space from Windows\n(Disk Management → shrink C:) before installing."
                return 1
            fi

            for (( g=min_gb; g<=detected_free_gb; g+=step_gb )); do
                local pct=$(( g * 100 / TOTAL_DISK_SIZE ))
                local win_left=$(( detected_free_gb - g ))
                local flag=OFF
                [[ "$SPLIT_PERCENT" -gt 0 && $(( TOTAL_DISK_SIZE * SPLIT_PERCENT / 100 )) -eq $g ]] && flag=ON
                # default to middle
                [[ $g -eq $(( (min_gb + detected_free_gb) / 2 / step_gb * step_gb )) && "$flag" == "OFF" ]] && flag=ON
                SLIDER_ITEMS+=("$g" "${g}GB for Zerene  (~${pct}% of disk)  ·  ${win_left}GB stays for existing OS" "$flag")
            done

            # add exact free space as last option if not already included
            local last_g=$(( detected_free_gb ))
            if (( last_g % step_gb != 0 )); then
                local pct=$(( last_g * 100 / TOTAL_DISK_SIZE ))
                SLIDER_ITEMS+=("$last_g" "${last_g}GB for Zerene  (ALL free space)  ·  0GB stays for existing OS" OFF)
            fi

            local chosen_gb
            chosen_gb=$(whiptail --title "  Disk Split  " --separate-output \
                --radiolist \
                "Disk: ${TARGET_DISK} (${TOTAL_DISK_SIZE}GB total)\nFree space available: ~${detected_free_gb}GB\n\nSelect how much free space to give Zerene:\n(Existing OS partitions are NOT touched)\n\n[ESC = go back]" \
                26 78 14 "${SLIDER_ITEMS[@]}" 3>&1 1>&2 2>&3) || return 1

            ZERENE_SIZE_GB="$chosen_gb"
            OTHER_SIZE_GB=$(( detected_free_gb - chosen_gb ))
            SPLIT_PERCENT=$(( chosen_gb * 100 / TOTAL_DISK_SIZE ))
            FREE_DISK_SPACE=$OTHER_SIZE_GB
            ;;
    esac
}

