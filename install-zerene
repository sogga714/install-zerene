    "10" "Budgie        clean and simple" \
    "11" "Deepin        polished desktop env" \
    "12" "Openbox       bare window manager only" \
    "13" "bspwm         tiling wm, scriptable" \
    "14" "Qtile         python tiling wm" \
    "15" "COSMIC        new rust desktop from system76" \
    "16" "WindowMaker   classic NeXTSTEP look and feel" \
    "17" "Fluxbox       fast and light, tabbed windows" \
    "18" "IceWM         ultra lightweight, taskbar wm" \
    "19" "Enlightenment e26, effects and compositing" \
    "20" "Niri          scrollable wayland tiling wm" \
    "21" "River         wayland dynamic tiling wm" \
    "22" "Wayfire       wayland compositor, 3d effects" \
    "23" "Herbstluftwm  manual tiling, ipc driven" \
    "24" "dwm           suckless dynamic wm, patched" \
    "25" "awesome       lua configured tiling wm" \
    "26" "spectrwm      minimalist bsd-style tiling" \
    "27" "LXDE          lightest full de, gtk2" \
    "28" "Pantheon      elementary os desktop" \
    "29" "Plasma Mobile kde mobile shell" \
    "30" "Xorg only     - minimal X without desktop" \
    "31" "Server        - no GPU, headless optimized" \
    "32" "None          no desktop") || err "cancelled"

header "AUR Helper"

aur_helper=$(tui_menu "AUR Helper" "Select AUR helper to install:" \
    "1" "yay   - go based, most popular" \
    "2" "paru  - rust based, faster" \
    "3" "none  - skip") || err "cancelled"

header "GPU Driver"

gpu_choice=$(tui_menu "GPU Driver" "Select GPU driver:" \
