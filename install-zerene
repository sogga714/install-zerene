header "Swap & ZRAM"

# show detected ram so the user knows what they're working with
swap_choice=$(tui_menu "Swap & ZRAM" "Detected RAM: ${RAM_MB}MB\n\nSelect a memory configuration:" \
    "1" "ZRAM only      - compressed ram swap, no disk swap (recommended)" \
    "2" "Swapfile only  - traditional file-based swap on disk" \
    "3" "ZRAM + Swap    - both zram and a swapfile (best for low ram)" \
    "4" "None           - skip swap entirely") || err "cancelled"

# only ask about hibernation if they picked something with a swapfile
# hibernation requires a real swapfile on disk - zram alone cant do it
HIBERNATION=false
SWAP_SIZE_MB=0
ZRAM_SIZE_MB=0

if [[ "$swap_choice" == "1" || "$swap_choice" == "3" ]]; then
    # zram size: half ram for normal, full ram for hibernation capable
    if tui_yesno "Hibernation" "Do you want to enable hibernation support?\n\nDetected RAM: ${RAM_MB}MB\n\n  Yes → swapfile = ${RAM_MB}MB  (full ram, needed for hibernation)\n  No  → zram = $(( RAM_MB / 2 ))MB  (half ram, lighter on disk)"; then
        HIBERNATION=true
        ZRAM_SIZE_MB=$RAM_MB
    else
        HIBERNATION=false
        ZRAM_SIZE_MB=$(( RAM_MB / 2 ))
    fi
fi

if [[ "$swap_choice" == "2" || "$swap_choice" == "3" ]]; then
    # swapfile is always full ram size so hibernation can work if ever enabled
    if tui_yesno "Hibernation" "Do you want to enable hibernation support?\n\nDetected RAM: ${RAM_MB}MB\n\n  Yes → swapfile = ${RAM_MB}MB  (full ram, required for hibernate)\n  No  → swapfile = $(( RAM_MB / 2 ))MB  (half ram is enough for most uses)"; then
        HIBERNATION=true
        SWAP_SIZE_MB=$RAM_MB
    else
        HIBERNATION=false
        SWAP_SIZE_MB=$(( RAM_MB / 2 ))
    fi
    # if zram+swap combo, zram is always half regardless
    [[ "$swap_choice" == "3" && "$ZRAM_SIZE_MB" -eq 0 ]] && ZRAM_SIZE_MB=$(( RAM_MB / 2 ))
fi

# readable swap summary for confirm screen
case "$swap_choice" in
    1) SWAPN="zram ${ZRAM_SIZE_MB}MB zstd" ;;
    2) SWAPN="swapfile ${SWAP_SIZE_MB}MB" ;;
    3) SWAPN="zram ${ZRAM_SIZE_MB}MB + swapfile ${SWAP_SIZE_MB}MB" ;;
    4) SWAPN="none" ;;
esac
[[ "$HIBERNATION" == "true" ]] && SWAPN="$SWAPN  (hibernation enabled)"

# tune swappiness based on what swap the user chose
# no swap = 0 (kernel never tries to swap), zram only = 100 (zram is fast, swap aggressively),
# swapfile = 10 (slow disk, avoid swapping), zram+swap = 60 (middle ground)
case "$swap_choice" in
    1) SWAPPINESS=100 ;;   # zram only - fast compressed ram, swap freely
    2) SWAPPINESS=10 ;;    # swapfile on disk - slow, avoid unless necessary
    3) SWAPPINESS=60 ;;    # zram + swapfile - balanced
    4) SWAPPINESS=0 ;;     # no swap - never swap
esac
