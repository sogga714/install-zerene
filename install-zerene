# --------------------------------------------------------
# navigation system
# all interactive functions return:
#   0 = ok / next
#   1 = go back (user pressed "Back" or ESC)
#   exits on hard cancel from err()
# --------------------------------------------------------

GO_BACK=1
GO_NEXT=0

tui_menu() {
    local title="$1" prompt="$2"; shift 2
    # inject a "← Back" item as the FIRST option
    local result
    result=$(whiptail --title "  $title  " --menu "$prompt\n\n[Use arrow keys  ·  Tab to switch  ·  ESC or Back = previous step]" 24 76 15 \
        "BACK" "← Go back to previous step" "$@" 3>&1 1>&2 2>&3) || return $GO_BACK
    [[ "$result" == "BACK" ]] && return $GO_BACK
    echo "$result"
    return $GO_NEXT
}

tui_yesno() {
    whiptail --title "  $1  " --yesno "$2" 10 62
}

tui_input() {
    local title="$1" prompt="$2" default="${3:-}"
    local result
    result=$(whiptail --title "  $title  " --inputbox "$prompt\n\n[ESC = go back]" 12 68 "$default" 3>&1 1>&2 2>&3) || return $GO_BACK
    echo "$result"
    return $GO_NEXT
}

tui_pass() {
    local result
    result=$(whiptail --title "  $1  " --passwordbox "$2\n\n[ESC = go back]" 12 62 3>&1 1>&2 2>&3) || return $GO_BACK
    echo "$result"
    return $GO_NEXT
}

tui_msg() {
    whiptail --title "  $1  " --msgbox "$2" 12 66
}

tui_radiolist() {
    local title="$1" prompt="$2"; shift 2
    local result
    result=$(whiptail --title "  $title  " --radiolist "$prompt\n\n[ESC = go back]" 24 76 15 \
        "BACK" "← Go back to previous step" OFF "$@" 3>&1 1>&2 2>&3) || return $GO_BACK
    [[ "$result" == "BACK" ]] && return $GO_BACK
    echo "$result"
    return $GO_NEXT
}

tui_checklist() {
    local title="$1" prompt="$2"; shift 2
    local result
    result=$(whiptail --title "  $title  " --checklist "$prompt\n\n[ESC = go back  ·  Space = toggle]" 24 76 15 "$@" 3>&1 1>&2 2>&3) || return $GO_BACK
    echo "$result"
    return $GO_NEXT
}

tui_scrollbox() {
    local title="$1" text="$2"
    echo "$text" | whiptail --title "  $title  " --scrollbox 24 80 3>&1 1>&2 2>&3
}

