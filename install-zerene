echo "--------------------------"
figlet Installing MAINSYS
echo "--------------------------"


if [[ "$FORMAT_DISK" == "true" || "$SPLIT_DISK" == "true" ]]; then
    step "Partitioning $TARGET_DISK ($FS_TYPE, $BOOT_MODE)"
    swapoff -a

    if [[ "$BOOT_MODE" == "uefi" ]]; then
        # uefi - gpt partition table with esp
        parted -s "$TARGET_DISK" mklabel gpt
        parted -s "$TARGET_DISK" mkpart ESP fat32 1MiB 513MiB
        parted -s "$TARGET_DISK" set 1 esp on

        if [[ "$SPLIT_DISK" == "true" ]]; then
            # split disk - create partition for zerene based on percentage
            parted -s "$TARGET_DISK" mkpart primary ${ZERENE_SIZE_GB}MiB ${ZERENE_SIZE_GB}MiB
        else
            # full disk
            parted -s "$TARGET_DISK" mkpart primary 513MiB 100%
        fi
        mkfs.fat -F32 "${TARGET_DISK}${P}1"
    else
        # legacy bios - msdos partition table with bios_grub partition
        parted -s "$TARGET_DISK" mklabel msdos
        parted -s "$TARGET_DISK" mkpart primary 1MiB 3MiB
        parted -s "$TARGET_DISK" set 1 bios_grub on

        if [[ "$SPLIT_DISK" == "true" ]]; then
            # split disk
            parted -s "$TARGET_DISK" mkpart primary 3MiB ${ZERENE_SIZE_GB}MiB
        else
            # full disk
            parted -s "$TARGET_DISK" mkpart primary 3MiB 100%
        fi
        parted -s "$TARGET_DISK" set 2 boot on
    fi

    # format root partition based on chosen filesystem
    case "$FS_TYPE" in
        ext4)
            pacman -S --noconfirm e2fsprogs &>/dev/null || true
            mkfs.ext4 -L "ZERENE_OS" "${TARGET_DISK}${P}2"
            ;;
        btrfs)
            pacman -S --noconfirm btrfs-progs &>/dev/null || true
            mkfs.btrfs -f -L "ZERENE_OS" "${TARGET_DISK}${P}2"
            ;;
        xfs)
            pacman -S --noconfirm xfsprogs &>/dev/null || true
            mkfs.xfs -f -L "ZERENE_OS" "${TARGET_DISK}${P}2"
            ;;
        f2fs)
            pacman -S --noconfirm f2fs-tools &>/dev/null || true
            mkfs.f2fs -f -l "ZERENE_OS" "${TARGET_DISK}${P}2"
            ;;
        bcachefs)
            pacman -S --noconfirm bcachefs-tools &>/dev/null || true
            bcachefs format -L "ZERENE_OS" "${TARGET_DISK}${P}2"
            ;;
    esac
fi

# mount based on filesystem type
if [[ "$FS_TYPE" == "btrfs" ]]; then
    step "Creating Btrfs Subvolumes"
    mount "${TARGET_DISK}${P}2" /mnt
    btrfs subvolume create /mnt/@
    btrfs subvolume create /mnt/@home
    btrfs subvolume create /mnt/@snapshots
    umount /mnt

    step "Mounting Btrfs Subvolumes"
    # Mount with zstd compression to help that HDD speed
    mount -o noatime,compress=zstd,subvol=@ "${TARGET_DISK}${P}2" /mnt
    mkdir -p /mnt/{boot/efi,home,.snapshots}
    mount -o noatime,compress=zstd,subvol=@home "${TARGET_DISK}${P}2" /mnt/home
    mount -o noatime,compress=zstd,subvol=@snapshots "${TARGET_DISK}${P}2" /mnt/.snapshots
else
    step "Mounting $FS_TYPE Partition"
    mount "${TARGET_DISK}${P}2" /mnt
    if [[ "$BOOT_MODE" == "uefi" ]]; then
        mkdir -p /mnt/boot/efi
    else
        mkdir -p /mnt/boot
    fi
    mkdir -p /mnt/home
fi

# mount boot partition
if [[ "$BOOT_MODE" == "uefi" ]]; then
