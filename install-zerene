step "Installing Base System + Generation Tools"
# Added btrfs-progs and grub-btrfs for btrfs, xfsprogs for xfs, etc.
FS_TOOLS=""
[[ "$FS_TYPE" == "btrfs" ]]    && FS_TOOLS="btrfs-progs grub-btrfs inotify-tools"
[[ "$FS_TYPE" == "xfs" ]]      && FS_TOOLS="xfsprogs"
[[ "$FS_TYPE" == "f2fs" ]]     && FS_TOOLS="f2fs-tools"
[[ "$FS_TYPE" == "bcachefs" ]] && FS_TOOLS="bcachefs-tools"

PRIV_PKG="sudo"
[[ "$priv_choice" == "2" ]] && PRIV_PKG="opendoas"

pacstrap /mnt base "$KERNEL_PKG" "$KERNEL_HEADERS" linux-firmware \
    "$PRIV_PKG" fastfetch plymouth $NET_PKG base-devel git dkms \
    $FS_TOOLS $EXTRA_PKGS

# Generate FSTAB (Crucial for Btrfs subvolumes)
genfstab -U /mnt >> /mnt/etc/fstab

# advanced kernel or auto-config
if [[ "$ADVANCED_KERNEL" == "true" ]]; then
    step "Kernel Source Build"
    arch-chroot /mnt bash <<KCONF
        pacman -S --noconfirm asp base-devel
        mkdir -p /root/kernelbuild && cd /root/kernelbuild
        asp export linux && cd linux
        zcat /proc/config.gz > .config 2>/dev/null || \
            cp /usr/lib/modules/\$(uname -r)/build/.config .config 2>/dev/null || \
            make defconfig
        case "$kconfig_method" in
            1) pacman -S --noconfirm ncurses; make menuconfig ;;
            2) pacman -S --noconfirm qt5-base; make xconfig ;;
            3) pacman -S --noconfirm vim; vim .config ;;
            4) pacman -S --noconfirm nano; nano .config ;;
        esac
        read -rp "Build and install kernel now? [Y/n]: " b
        if [[ ! "\$b" =~ ^[Nn]$ ]]; then
            make -j\$(nproc)
            make modules_install
            make install
        fi
KCONF
elif [[ "$AUTO_CONFIG" == "true" ]]; then
    # write the generated .config to a file for review and optional editing
    step "Applying Auto-generated Kernel Config"

    # write config to temp location in chroot
    echo "$AUTO_CONFIG_CONTENT" > /mnt/root/zerene-kernel-config.txt

    # show it in a scrollbox so user can review
    tui_scrollbox "Kernel Config" "$AUTO_CONFIG_CONTENT"

    # ask if they want to use it, edit it, or go with defaults
    config_action=$(tui_menu "Kernel Config" "Your auto-generated .config has been created.\nWhat would you like to do?" \
        "1" "Use as-is    - install with this config" \
        "2" "Edit config  - modify before building" \
        "3" "Use default  - use arch's default config") || err "cancelled"

    case "$config_action" in
        1)
            # use auto-config - apply it during kernel build
            ARCH_KCONF='yes' | chroot /mnt bash -c 'mkdir -p /root/kernelbuild && cd /root/kernelbuild && asp export linux && cd linux'
            echo "$AUTO_CONFIG_CONTENT" > /mnt/root/linux/.config
            msg "Auto-config applied"
            ;;
        2)
            # edit config
            arch-chroot /mnt bash <<KEDIT
                pacman -S --noconfirm nano
                mkdir -p /root/kernelbuild && cd /root/kernelbuild
                asp export linux && cd linux
                zcat /proc/config.gz > .config 2>/dev/null || make defconfig
                nano .config
                read -rp "Save and build kernel now? [Y/n]: " b
                if [[ ! "\$b" =~ ^[Nn]$ ]]; then
                    make -j\$(nproc) && make modules_install && make install
                fi
KEDIT
            ;;
        3)
            # use default - just install package normally
            msg "Using default kernel config"
            ;;
    esac
fi

clear

