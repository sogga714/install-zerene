    step "Kernel Source Build"
    arch-chroot /mnt bash <<KCONF
        pacman -S --noconfirm asp base-devel
        mkdir -p /root/kernelbuild && cd /root/kernelbuild
        asp export linux && cd linux
        zcat /proc/config.gz > .config 2>/dev/null || \
            cp /usr/lib/modules/\$(uname -r)/build/.config .config 2>/dev/null || \
            make defconfig
        case "$kconfig_method" in
            1) pacman -S --noconfirm ncurses; make menuconfig ;;
            2) pacman -S --noconfirm qt5-base; make xconfig ;;
            3) pacman -S --noconfirm vim; vim .config ;;
            4) pacman -S --noconfirm nano; nano .config ;;
        esac
        read -rp "Build and install kernel now? [Y/n]: " b
        if [[ ! "\$b" =~ ^[Nn]$ ]]; then
            make -j\$(nproc)
            make modules_install
            make install
        fi
KCONF
elif [[ "$AUTO_CONFIG" == "true" ]]; then
    # write the generated .config to a file for review and optional editing
    step "Applying Auto-generated Kernel Config"

    # write config to temp location in chroot
    echo "$AUTO_CONFIG_CONTENT" > /mnt/root/zerene-kernel-config.txt

