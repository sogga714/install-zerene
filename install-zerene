    curl -L "http://download.opensuse.org/tumbleweed/appliances/opensuse-tumbleweed-image.x86_64-networkd.tar.xz" \
         -o /tempo/opensuse-workspace/opensuse.tar.xz
    tar -xf /tempo/opensuse-workspace/opensuse.tar.xz -C /subspace/opensuse
    rm -rf /tempo
    cp /etc/resolv.conf /subspace/opensuse/etc/resolv.conf
    cat > /usr/local/bin/subspace-opensuse <<'OPENSUSE'
#!/bin/bash
xhost +local: > /dev/null 2>&1
if [ -n "\$DISPLAY" ]; then
    sudo systemd-nspawn -q -D /subspace/opensuse --bind-ro=/etc/resolv.conf --bind-ro=/tmp/.X11-unix --bind=/dev/dri --setenv=DISPLAY=\$DISPLAY /bin/sh
else
    sudo systemd-nspawn -q -D /subspace/opensuse /bin/sh
fi
OPENSUSE
    chmod +x /usr/local/bin/subspace-opensuse
    echo "alias opensuse='/usr/local/bin/subspace-opensuse'" >> /home/$username/.bashrc
fi

if [[ "$INSTALL_DEBIAN" == "false" && "$INSTALL_ALPINE" == "false" && "$INSTALL_GENTOO" == "false" && \
      "$INSTALL_VOID" == "false" && "$INSTALL_FEDORA" == "false" && "$INSTALL_OPENSUSE" == "false" ]]; then
    echo "  > no subspaces selected"
fi

clear
echo "--------------------------"
figlet Snapshots
echo "--------------------------"

pacman -S --noconfirm snapper snap-pac grub-btrfs
snapper -c root create-config / 2>&1 || echo "WARNING: snapper create-config failed, will retry on first boot"
systemctl enable snapper-timeline.timer
systemctl enable snapper-cleanup.timer

if ! grep -q "snapshot()" /home/$username/.bashrc 2>/dev/null; then
    cat >> /home/$username/.bashrc << 'SNAPPA'

snapshot() {
    if [ -z "\$1" ]; then echo "Usage: snapshot <description>"; return 1; fi
    sudo snapper -c root create --description "\$*"
}
SNAPPA
fi

mkdir -p /etc/pacman.d/hooks
cat > /etc/pacman.d/hooks/95-snapper-grub.hook << 'REGEN'
[Trigger]
Operation = Install
Operation = Upgrade
Operation = Remove
Type = Package
Target = *

[Action]
Description = Regenerating GRUB configuration...
When = PostTransaction
Exec = /usr/bin/grub-mkconfig -o /boot/grub/grub.cfg
REGEN
chmod 644 /etc/pacman.d/hooks/95-snapper-grub.hook

clear
echo "--------------------------"
figlet Bootloader
echo "--------------------------"

if [[ "$BOOT_MODE" == "uefi" ]]; then
    pacman -S --noconfirm grub efibootmgr
    grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=zerene
else
    pacman -S --noconfirm grub
    grub-install --target=i386-pc "$TARGET_DISK"
fi

systemctl enable grub-btrfsd
grub-mkconfig -o /boot/grub/grub.cfg

cat > /etc/zerene-tune.txt <<TUNE
zerene auto tuning - applied at install

cpu:        $CPU_MODEL_NAME
cores:      $CPU_CORES
ram:        ${RAM_MB}mb
disk:       $DISK_TYPE
laptop:     $IS_LAPTOP
vm:         $IS_VM
kernel:     $KERNEL_PKG
timezone:   $TIMEZONE
mirrors:    ${MIRROR_COUNTRY:-default}
TUNE

clear
echo "--------------------------"
figlet Finalizing
echo "--------------------------"

plymouth-set-default-theme -R zerene-spinner 2>/dev/null || true
mkinitcpio -P
pacman -R --noconfirm figlet 2>/dev/null || true
EOF

step "Unmounting"
umount -R /mnt 2>/dev/null || true
ok "done"

# --------------------------------------------------------
# finish
# --------------------------------------------------------
echo
echo "--------------------------"
figlet Install finished!
echo "--------------------------"
rule
fastfetch
echo
echo -e "${BLUE}${BOLD}    Zerene OS installed successfully  ·  VER : XENOVIA 2"
echo
echo -e "${GRAY}    filesystem: $FS_TYPE  ·  boot: $BOOT_MODE${RESET}"
echo -e "${GRAY}    timezone:   $TIMEZONE${RESET}"
echo -e "${GRAY}    mirrors:    ${MIRROR_COUNTRY:-default}${RESET}"
echo -e "${GRAY}    disk:       $([ "$FORMAT_DISK" == "true" ] && echo "full format" || echo "split ${ZERENE_SIZE_GB}GB Zerene / ${OTHER_SIZE_GB}GB existing")${RESET}"
echo -e "${GRAY}    tuning report  →  /etc/zerene-tune.txt${RESET}"
echo -e "${GRAY}    you can now reboot${RESET}"
echo "If you do not see any snapshots or cannot create any, run: snapper -c root create-config /"
rule
echo
