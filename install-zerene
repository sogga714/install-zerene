# --------------------------------------------------------
# step list - defines order and supports going back
# --------------------------------------------------------

STEPS=(
    "step_identity"
    "step_timezone"
    "step_mirrors"
    "step_disk"
    "step_disk_option"
    "step_filesystem"
    "step_nix"
    "step_kernel"
    "step_system"
    "step_desktop"
    "step_aur"
    "step_gpu"
    "step_network"
    "step_swap"
    "step_subspaces"
    "step_extra_pkgs"
    "step_confirm"
)

CURRENT_STEP=0
TOTAL_STEPS=${#STEPS[@]}

while [[ $CURRENT_STEP -lt $TOTAL_STEPS ]]; do
    step_fn="${STEPS[$CURRENT_STEP]}"
    $step_fn
    result=$?

    if [[ $result -eq 0 ]]; then
        # advance
        (( CURRENT_STEP++ ))
    else
        # go back
        if [[ $CURRENT_STEP -gt 0 ]]; then
            (( CURRENT_STEP-- ))
        fi
        # if already at step 0 and they pressed back - ask if they want to cancel
        if [[ $CURRENT_STEP -eq 0 && $result -ne 0 ]]; then
            tui_yesno "Cancel Installation" "Go back to the very first step?\n\nPress No to cancel the installer entirely." || err "installation cancelled by user"
        fi
    fi
done

# --------------------------------------------------------
# installation - output is visible from here on
# --------------------------------------------------------

clear

echo "--------------------------"
figlet Installing MAINSYS
echo "--------------------------"

# Apply mirrors if selected
if [[ "$MIRROR_COUNTRY" != "skip" && -n "$MIRROR_COUNTRY" ]]; then
    step "Fetching mirrors for: $MIRROR_COUNTRY"
    if command -v reflector &>/dev/null; then
        reflector --country "$MIRROR_COUNTRY" --sort rate --save /etc/pacman.d/mirrorlist --latest 10 \
            || warn "reflector failed, using existing mirror list"
    else
        pacman -S --noconfirm reflector &>/dev/null
        reflector --country "$MIRROR_COUNTRY" --sort rate --save /etc/pacman.d/mirrorlist --latest 10 \
            || warn "reflector failed, using existing mirror list"
    fi
    ok "mirrors updated for $MIRROR_COUNTRY"
fi

if [[ "$FORMAT_DISK" == "true" || "$SPLIT_DISK" == "true" ]]; then
    step "Partitioning $TARGET_DISK ($FS_TYPE, $BOOT_MODE)"
    swapoff -a

    if [[ "$BOOT_MODE" == "uefi" ]]; then
        if [[ "$FORMAT_DISK" == "true" ]]; then
            # full format - new gpt table
            parted -s "$TARGET_DISK" mklabel gpt
            parted -s "$TARGET_DISK" mkpart ESP fat32 1MiB 513MiB
            parted -s "$TARGET_DISK" set 1 esp on
            parted -s "$TARGET_DISK" mkpart primary 513MiB 100%
            mkfs.fat -F32 "${TARGET_DISK}${P}1"
        else
            # split: find the start of free space and carve out Zerene partition
            # assume EFI already exists from Windows - use the free region
            local FREE_START_MIB
            FREE_START_MIB=$(parted -s "$TARGET_DISK" unit MiB print free 2>/dev/null | \
                awk '/Free Space/{print $1}' | tr -d 'MiB' | sort -rn | head -1)
            local ZERENE_END_MIB=$(( FREE_START_MIB + ZERENE_SIZE_GB * 1024 ))
            parted -s "$TARGET_DISK" mkpart primary "${FREE_START_MIB}MiB" "${ZERENE_END_MIB}MiB"
            # find the existing EFI partition (type=esp)
            local EFI_PART
            EFI_PART=$(parted -s "$TARGET_DISK" print 2>/dev/null | awk '/esp/{print $1}' | head -1)
            if [[ -n "$EFI_PART" ]]; then
                step "Reusing existing EFI partition: ${TARGET_DISK}${P}${EFI_PART}"
                mkfs.fat -F32 "${TARGET_DISK}${P}${EFI_PART}" 2>/dev/null || true
            fi
            # the new Zerene partition is the last one
            local NEW_PART
            NEW_PART=$(lsblk -no NAME "$TARGET_DISK" | tail -1)
            TARGET_ROOT="/dev/$NEW_PART"
        fi
    else
        if [[ "$FORMAT_DISK" == "true" ]]; then
            parted -s "$TARGET_DISK" mklabel msdos
            parted -s "$TARGET_DISK" mkpart primary 1MiB 3MiB
            parted -s "$TARGET_DISK" set 1 bios_grub on
            parted -s "$TARGET_DISK" mkpart primary 3MiB 100%
            parted -s "$TARGET_DISK" set 2 boot on
        else
            local FREE_START_MIB
            FREE_START_MIB=$(parted -s "$TARGET_DISK" unit MiB print free 2>/dev/null | \
                awk '/Free Space/{print $1}' | tr -d 'MiB' | sort -rn | head -1)
            local ZERENE_END_MIB=$(( FREE_START_MIB + ZERENE_SIZE_GB * 1024 ))
            parted -s "$TARGET_DISK" mkpart primary "${FREE_START_MIB}MiB" "${ZERENE_END_MIB}MiB"
            local NEW_PART
            NEW_PART=$(lsblk -no NAME "$TARGET_DISK" | tail -1)
            TARGET_ROOT="/dev/$NEW_PART"
        fi
    fi

    # figure out which partition is the root (for full format it's always P2)
    if [[ "$FORMAT_DISK" == "true" ]]; then
        TARGET_ROOT="${TARGET_DISK}${P}2"
    fi
    # TARGET_ROOT is set above for split case

    # format root
    case "$FS_TYPE" in
        btrfs)
            pacman -S --noconfirm btrfs-progs &>/dev/null || true
            mkfs.btrfs -f -L "ZERENE_OS" "$TARGET_ROOT"
            ;;
    esac
fi

# determine root partition for mounting when no format happened
if [[ -z "$TARGET_ROOT" ]]; then
    TARGET_ROOT="${TARGET_DISK}${P}2"
fi

if [[ "$FS_TYPE" == "btrfs" ]]; then
    step "Creating Btrfs Subvolumes"
    mount "$TARGET_ROOT" /mnt
    btrfs subvolume create /mnt/@
    btrfs subvolume create /mnt/@home
    btrfs subvolume create /mnt/@snapshots
    umount /mnt

    step "Mounting Btrfs Subvolumes"
    mount -o noatime,compress=zstd,subvol=@ "$TARGET_ROOT" /mnt
    mkdir -p /mnt/{boot/efi,home,.snapshots}
    mount -o noatime,compress=zstd,subvol=@home "$TARGET_ROOT" /mnt/home
    mount -o noatime,compress=zstd,subvol=@snapshots "$TARGET_ROOT" /mnt/.snapshots
else
    step "Mounting Partition"
    mount "$TARGET_ROOT" /mnt
    mkdir -p /mnt/{boot/efi,home}
fi

if [[ "$BOOT_MODE" == "uefi" ]]; then
    if [[ "$FORMAT_DISK" == "true" ]]; then
        mount "${TARGET_DISK}${P}1" /mnt/boot/efi
    else
        # mount existing EFI partition
        EFI_PART=$(parted -s "$TARGET_DISK" print 2>/dev/null | awk '/esp/{print $1}' | head -1)
        [[ -n "$EFI_PART" ]] && mount "${TARGET_DISK}${P}${EFI_PART}" /mnt/boot/efi
    fi
fi

INSTALL_NIX=false
if [[ "$nix_choice" == "1" ]]; then
    INSTALL_NIX=true
    mkdir -p /mnt/nix/{store,var/nix/db,var/nix/profiles,var/nix/channel-cache}
    chmod -R 1775 /mnt/nix/store
    mkdir -p /mnt/var/empty
fi

step "Installing Base System"
FS_TOOLS=""
[[ "$FS_TYPE" == "btrfs" ]] && FS_TOOLS="btrfs-progs grub-btrfs inotify-tools"

PRIV_PKG="sudo"
[[ "$priv_choice" == "2" ]] && PRIV_PKG="opendoas"

pacstrap /mnt base "$KERNEL_PKG" "$KERNEL_HEADERS" linux-firmware \
    "$PRIV_PKG" fastfetch plymouth $NET_PKG base-devel git dkms \
    $FS_TOOLS $EXTRA_PKGS

genfstab -U /mnt >> /mnt/etc/fstab

if [[ "$ADVANCED_KERNEL" == "true" ]]; then
    step "Kernel Source Build"
    arch-chroot /mnt bash <<KCONF
        pacman -S --noconfirm asp base-devel
        mkdir -p /root/kernelbuild && cd /root/kernelbuild
        asp export linux && cd linux
        zcat /proc/config.gz > .config 2>/dev/null || make defconfig
        case "$kconfig_method" in
            1) pacman -S --noconfirm ncurses; make menuconfig ;;
            2) pacman -S --noconfirm qt5-base; make xconfig ;;
            3) pacman -S --noconfirm vim; vim .config ;;
            4) pacman -S --noconfirm nano; nano .config ;;
        esac
        read -rp "Build and install kernel now? [Y/n]: " b
        [[ ! "\$b" =~ ^[Nn]$ ]] && make -j\$(nproc) && make modules_install && make install
KCONF
elif [[ "$AUTO_CONFIG" == "true" ]]; then
    step "Applying Auto-generated Kernel Config"
    echo "$AUTO_CONFIG_CONTENT" > /mnt/root/zerene-kernel-config.txt
    tui_scrollbox "Kernel Config" "$AUTO_CONFIG_CONTENT"
    config_action=$(tui_menu "Kernel Config" "Your auto-generated .config has been created.\nWhat would you like to do?" \
        "1" "Use as-is    - install with this config" \
        "2" "Edit config  - modify before building" \
        "3" "Use default  - use arch's default config")
    case "$config_action" in
        1) echo "$AUTO_CONFIG_CONTENT" > /mnt/root/linux/.config; msg "Auto-config applied" ;;
        2)
            arch-chroot /mnt bash <<KEDIT
                pacman -S --noconfirm nano
                mkdir -p /root/kernelbuild && cd /root/kernelbuild
                asp export linux && cd linux
                zcat /proc/config.gz > .config 2>/dev/null || make defconfig
                nano .config
                read -rp "Build now? [Y/n]: " b
                [[ ! "\$b" =~ ^[Nn]$ ]] && make -j\$(nproc) && make modules_install && make install
KEDIT
            ;;
        3) msg "Using default kernel config" ;;
    esac
fi

clear
echo "--------------------------"
figlet Assets
echo "--------------------------"

mkdir -p /mnt/etc/fastfetch
[ -d /etc/fastfetch ] && cp -r /etc/fastfetch/* /mnt/etc/fastfetch/
mkdir -p /mnt/usr/share/pixmaps
cp /usr/share/pixmaps/zerene.svg /mnt/usr/share/pixmaps/ 2>/dev/null || true
mkdir -p /mnt/usr/share/plymouth/themes/
cp -r /usr/share/plymouth/themes/zerene-spinner /mnt/usr/share/plymouth/themes/ 2>/dev/null || true
mkdir -p /mnt/usr/share/wallpapers-zerene/
cp -r /usr/share/wallpapers-zerene /mnt/usr/share 2>/dev/null || true
ok "assets copied"

# --------------------------------------------------------
# chroot
# --------------------------------------------------------
echo "--------------------------"
figlet Installing Zerene OS
echo "--------------------------"

arch-chroot /mnt bash <<EOF

pacman -S --noconfirm figlet

echo "$hostname" > /etc/hostname
echo "KEYMAP=$LAYOUT" > /etc/vconsole.conf

# timezone
ln -sf "/usr/share/zoneinfo/$TIMEZONE" /etc/localtime
hwclock --systohc
echo "  > timezone set: $TIMEZONE"

