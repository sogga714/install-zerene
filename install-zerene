[[ "$FS_TYPE" == "f2fs" ]]     && FS_TOOLS="f2fs-tools"
[[ "$FS_TYPE" == "bcachefs" ]] && FS_TOOLS="bcachefs-tools"

pacstrap /mnt base "$KERNEL_PKG" "$KERNEL_HEADERS" linux-firmware \
    sudo fastfetch plymouth $NET_PKG base-devel git dkms \
    $FS_TOOLS $EXTRA_PKGS

