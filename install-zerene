echo ""
echo -e "\033[38;2;5;4;216m  ──  GPU Drivers  ──\033[0m"
echo ""
case "$gpu_choice" in
    1)
        # nvidia modern - rtx/turing/4060 etc
        # install nvidia-dkms, utils, settings
        pacman -S --noconfirm nvidia-dkms nvidia-utils nvidia-settings \
            lib32-nvidia-utils libglvnd lib32-libglvnd opencl-nvidia

        # dkms builds the module for the installed kernel
        echo "  > running dkms autoinstall..."
        dkms autoinstall

        # add nvidia modules to initramfs before rebuild
        sed -i 's/^MODULES=(/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf

        # kms hook conflicts with nvidia early loading - causes black screen on wayland
        sed -i 's/ kms//' /etc/mkinitcpio.conf

        # rebuild initramfs with the nvidia modules in it
        echo "  > rebuilding initramfs..."
        mkinitcpio -P

        # blacklist nouveau so it cant load and fight nvidia
        echo "blacklist nouveau" > /etc/modprobe.d/blacklist-nouveau.conf
        echo "options nouveau modeset=0" >> /etc/modprobe.d/blacklist-nouveau.conf

        # pacman hook - auto rebuilds initramfs whenever nvidia-dkms updates
        mkdir -p /etc/pacman.d/hooks
        cat > /etc/pacman.d/hooks/nvidia.hook <<NVHOOK
