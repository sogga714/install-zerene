step_swap() {
    local sc
    sc=$(tui_menu "Swap & ZRAM" "Detected RAM: ${RAM_MB}MB\n\nSelect a memory configuration:" \
        "1" "ZRAM only      - compressed ram swap, no disk swap (recommended)" \
        "2" "Swapfile only  - traditional file-based swap on disk" \
        "3" "ZRAM + Swap    - both zram and a swapfile (best for low ram)" \
        "4" "None           - skip swap entirely") || return 1
    swap_choice="$sc"

    HIBERNATION=false
    SWAP_SIZE_MB=0
    ZRAM_SIZE_MB=0

    if [[ "$swap_choice" == "1" || "$swap_choice" == "3" ]]; then
        if tui_yesno "Hibernation" "Enable hibernation support?\n\nDetected RAM: ${RAM_MB}MB\n\n  Yes → zram = ${RAM_MB}MB  (full ram, needed for hibernation)\n  No  → zram = $(( RAM_MB / 2 ))MB  (half ram, lighter)"; then
            HIBERNATION=true
            ZRAM_SIZE_MB=$RAM_MB
        else
            HIBERNATION=false
            ZRAM_SIZE_MB=$(( RAM_MB / 2 ))
        fi
    fi

    if [[ "$swap_choice" == "2" || "$swap_choice" == "3" ]]; then
        if tui_yesno "Hibernation" "Enable hibernation support?\n\nDetected RAM: ${RAM_MB}MB\n\n  Yes → swapfile = ${RAM_MB}MB\n  No  → swapfile = $(( RAM_MB / 2 ))MB"; then
            HIBERNATION=true
            SWAP_SIZE_MB=$RAM_MB
        else
            HIBERNATION=false
            SWAP_SIZE_MB=$(( RAM_MB / 2 ))
        fi
        [[ "$swap_choice" == "3" && "$ZRAM_SIZE_MB" -eq 0 ]] && ZRAM_SIZE_MB=$(( RAM_MB / 2 ))
    fi

    case "$swap_choice" in
        1) SWAPN="zram ${ZRAM_SIZE_MB}MB zstd" ;;
        2) SWAPN="swapfile ${SWAP_SIZE_MB}MB" ;;
        3) SWAPN="zram ${ZRAM_SIZE_MB}MB + swapfile ${SWAP_SIZE_MB}MB" ;;
        4) SWAPN="none" ;;
    esac
    [[ "$HIBERNATION" == "true" ]] && SWAPN="$SWAPN  (hibernation enabled)"

    case "$swap_choice" in
        1) SWAPPINESS=100 ;;
        2) SWAPPINESS=10 ;;
        3) SWAPPINESS=60 ;;
        4) SWAPPINESS=0 ;;
    esac
    [[ "$RAM_MB" -lt 4096 && "$swap_choice" == "2" ]] && SWAPPINESS=30
}

