echo "--------------------------"
figlet GPU Drivers
echo "--------------------------"

case "$gpu_choice" in
    1)
        # nvidia modern - rtx/turing/4060 etc
        # install kernel headers first so dkms can build the module
        pacman -S --noconfirm "$KERNEL_HEADERS"

        # install nvidia-dkms, utils, settings
        pacman -S --noconfirm nvidia-dkms nvidia-utils nvidia-settings \
            lib32-nvidia-utils libglvnd lib32-libglvnd opencl-nvidia

        # run dkms build explicitly for the running kernel
        echo "  > building nvidia dkms module for current kernel..."
        dkms autoinstall

        # verify the modules were actually built before touching mkinitcpio
        KVER=\$(uname -r)
        if find /usr/lib/modules/\$KVER -name "nvidia.ko*" 2>/dev/null | grep -q .; then
            echo "  > nvidia modules confirmed, patching mkinitcpio..."
            # add nvidia modules to initramfs before rebuild
            sed -i 's/^MODULES=(/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf

            # kms hook conflicts with nvidia early loading - causes black screen on wayland
            sed -i 's/ kms//' /etc/mkinitcpio.conf

            # rebuild initramfs with the nvidia modules in it
            echo "  > rebuilding initramfs..."
            mkinitcpio -P
        else
            echo "  > WARNING: nvidia dkms modules not found in /usr/lib/modules/\$KVER"
            echo "  > skipping early KMS module injection (will load at runtime instead)"
            echo "  > you can run: dkms autoinstall && mkinitcpio -P after reboot if needed"
        fi

        # blacklist nouveau so it cant load and fight nvidia
        echo "blacklist nouveau" > /etc/modprobe.d/blacklist-nouveau.conf
        echo "options nouveau modeset=0" >> /etc/modprobe.d/blacklist-nouveau.conf

        # pacman hook - auto rebuilds initramfs whenever nvidia-dkms updates
        mkdir -p /etc/pacman.d/hooks
        cat > /etc/pacman.d/hooks/nvidia.hook <<NVHOOK
[Trigger]
Operation=Install
Operation=Upgrade
Operation=Remove
Type=Package
Target=nvidia-dkms

[Action]
Description=Updating initramfs after nvidia update...
When=PostTransaction
Exec=/usr/bin/mkinitcpio -P
NVHOOK
        ;;
    2)
        # nvidia legacy - pascal gtx 10xx and older, aur only since driver 590
        pacman -S --noconfirm git base-devel "$KERNEL_HEADERS"
        cd /tmp
        git clone https://aur.archlinux.org/nvidia-580xx-dkms.git
        chown -R "$username:$username" /tmp/nvidia-580xx-dkms
        cd /tmp/nvidia-580xx-dkms
        sudo -u "$username" makepkg -si --noconfirm
        cd /
        pacman -S --noconfirm nvidia-utils lib32-nvidia-utils libglvnd lib32-libglvnd
