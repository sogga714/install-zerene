#!/bin/bash

# zerene os installer - xenovia 2 - TEST VERSION
# This is a test version for development/testing purposes


BLUE='\033[38;2;5;4;216m'       # #0504D8 zerene blue
LBLUE='\033[38;2;100;110;255m'  # lighter blue for accents
WHITE='\033[1;37m'
GRAY='\033[38;2;160;160;180m'
DIM='\033[2m'
BOLD='\033[1m'
RED='\033[0;31m'
GREEN='\033[0;32m'
RESET='\033[0m'

# draw a horizontal rule
rule() { echo -e "${BLUE}$(printf '─%.0s' $(seq 1 60))${RESET}"; }

# section header like archinstall but zerene style
header() {
    echo
    rule
    echo -e "${BLUE}${BOLD}  $1${RESET}"
    rule
    echo
}

# status messages
msg()  { echo -e "${BLUE}  ›${RESET} $1"; }
ok()   { echo -e "${GREEN}  ✓${RESET} $1"; }
warn() { echo -e "${RED}  !${RESET} $1"; }
err()  { echo -e "${RED}  ERROR:${RESET} $1"; exit 1; }

# step label printed before running something visible
step() { echo -e "\n${BLUE}${BOLD}  ──  $1  ──${RESET}\n"; }

SPIN_PID=""

spin_start() {
    local label="${1:-working...}"
    local blades=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    local outer=('◢◤' '◥◣' '◤◢' '◣◥')
    (
        local i=0 b=0
        while true; do
            printf "\r${BLUE}  %s %s${RESET}  ${GRAY}%s${RESET}    " \
                "${blades[$b]}" "${outer[$i]}" "$label"
            sleep 0.07
            i=$(( (i+1) % 4 ))
            b=$(( (b+1) % 8 ))
        done
    ) &
    SPIN_PID=$!
}

spin_stop() {
    [[ -n "$SPIN_PID" ]] && kill "$SPIN_PID" 2>/dev/null && wait "$SPIN_PID" 2>/dev/null
    SPIN_PID=""
    printf "\r%-70s\r" " "
}

trap spin_stop EXIT

# --------------------------------------------------------
# whiptail wrappers - themed to zerene blue via NEWT_COLORS
# --------------------------------------------------------

# whiptail reads NEWT_COLORS to theme its dialogs
# root=blue bg, window=dark, title=bright blue, button=blue
export NEWT_COLORS='
root=,black
window=white,black
shadow=black,black
border=blue,black
title=brightblue,black
roottext=white,black
listbox=white,black
actlistbox=black,brightblue
sellistbox=black,brightblue
actsellistbox=black,brightblue
textbox=white,black
acttextbox=black,brightblue
button=black,brightblue
actbutton=white,blue
compactbutton=white,black
checkbox=white,black
actcheckbox=black,brightblue
entry=white,black
disentry=gray,black
label=brightblue,black
emptyscale=,black
fullscale=brightblue,black
helpline=black,brightblue
'

tui_menu() {
    local title="$1" prompt="$2"; shift 2
    whiptail --title "  $title  " --menu "$prompt" 22 72 14 "$@" 3>&1 1>&2 2>&3
}

tui_yesno() {
    whiptail --title "  $1  " --yesno "$2" 10 62
}

tui_input() {
    local title="$1" prompt="$2" default="${3:-}"
    whiptail --title "  $title  " --inputbox "$prompt" 10 62 "$default" 3>&1 1>&2 2>&3
}

tui_pass() {
    whiptail --title "  $1  " --passwordbox "$2" 10 62 3>&1 1>&2 2>&3
}

tui_msg() {
    whiptail --title "  $1  " --msgbox "$2" 12 62
}

# tui_radiolist - styled radiolist for single selection
tui_radiolist() {
    local title="$1" prompt="$2"; shift 2
    whiptail --title "  $title  " --radiolist "$prompt" 22 72 14 "$@" 3>&1 1>&2 2>&3
}

# tui_checklist - styled checklist for MULTIPLE selection
tui_checklist() {
    local title="$1" prompt="$2"; shift 2
    whiptail --title "  $title  " --checklist "$prompt" 22 72 14 "$@" 3>&1 1>&2 2>&3
}

# tui_scrollbox - for displaying generated .config content
tui_scrollbox() {
    local title="$1" text="$2"
    echo "$text" | whiptail --title "  $title  " --scrollbox 24 80 3>&1 1>&2 2>&3
}

# --------------------------------------------------------
# splash
# --------------------------------------------------------

clear
echo
echo -e "${BLUE}${BOLD}"
cat << 'LOGO'
     ███████╗███████╗██████╗ ███████╗███╗   ██╗███████╗
     ╚══███╔╝██╔════╝██╔══██╗██╔════╝████╗  ██║██╔════╝
       ███╔╝ █████╗  ██████╔╝█████╗  ██╔██╗ ██║█████╗
      ███╔╝  ██╔══╝  ██╔══██╗██╔══╝  ██║╚██╗██║██╔══╝
     ███████╗███████╗██║  ██║███████╗██║ ╚████║███████╗
     ╚══════╝╚══════╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═══╝╚══════╝
LOGO
echo -e "${RESET}"
echo -e "${GRAY}                  xenovia 2  ·  installer  ·  TEST${RESET}"
echo
rule
echo

# check whiptail
if ! command -v whiptail &>/dev/null; then
    msg "installing whiptail..."
    pacman -S --noconfirm libnewt &>/dev/null
fi

# internet check
msg "checking internet..."
if ! ping -c 1 -W 3 google.com &>/dev/null; then
    tui_msg "No Internet" "No internet connection detected.\n\nOpening nmtui — connect to your network then re-run the installer."
    nmtui
    ping -c 1 -W 3 google.com &>/dev/null || err "no internet, cannot continue"
fi
ok "connected"
echo

# --------------------------------------------------------
# hardware scan
# --------------------------------------------------------

spin_start "scanning hardware"
CPU_VENDOR=$(grep -m1 "vendor_id" /proc/cpuinfo | awk '{print $3}')
CPU_MODEL_NAME=$(grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | xargs)
CPU_CORES=$(nproc)
CPU_FAMILY=$(grep -m1 "cpu family" /proc/cpuinfo | awk '{print $4}')
CPU_MODEL=$(grep -m1 "^model[[:space:]]" /proc/cpuinfo | awk '{print $3}')
RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
RAM_HALF=$(( RAM_MB / 2 ))
IS_LAPTOP=false
IS_VM=false
DISK_TYPE="hdd"
SWAPPINESS=10

[ -d /sys/class/power_supply/BAT0 ] || [ -d /sys/class/power_supply/BAT1 ] && IS_LAPTOP=true
grep -qi "virtualbox\|vmware\|kvm\|qemu\|hyper-v" /sys/class/dmi/id/product_name 2>/dev/null && IS_VM=true

CPU_GEN=0
if [[ "$CPU_VENDOR" == "GenuineIntel" ]]; then
    CPU_GEN=$(grep -m1 "model name" /proc/cpuinfo | grep -oP "\d+(?:st|nd|rd|th) Gen" | grep -oP "^\d+" || echo 0)
fi
spin_stop

ok "hardware scanned: ${CPU_MODEL_NAME} · ${CPU_CORES} cores · ${RAM_MB}MB RAM"

# autodetect boot mode - uefi or legacy bios
if [ -d /sys/firmware/efi/efivars ]; then
    BOOT_MODE="uefi"
    ok "boot mode: UEFI detected"
else
    BOOT_MODE="legacy"
    ok "boot mode: Legacy BIOS detected"
fi
echo

# --------------------------------------------------------
# configuration - all questions before anything installs
# --------------------------------------------------------

header "System Identity"

hostname=$(tui_input "Hostname" "Enter a hostname for this machine:" "zerene") || err "cancelled"
username=$(tui_input "User Account" "Enter your username:") || err "cancelled"
password=$(tui_pass "User Account" "Enter password:") || err "cancelled"
password2=$(tui_pass "User Account" "Confirm password:") || err "cancelled"
[[ "$password" != "$password2" ]] && err "passwords do not match"

header "Disk"

DISK_LIST=()
while IFS= read -r line; do
    name=$(echo "$line" | awk '{print $1}')
    size=$(echo "$line" | awk '{print $2}')
    model=$(echo "$line" | awk '{$1=$2=""; print $0}' | xargs)
    DISK_LIST+=("$name" "$size  $model")
done < <(lsblk -dno NAME,SIZE,MODEL | grep -v "loop")

DISK_ID=$(tui_menu "Disk Selection" "Select the disk to install Zerene OS on:" "${DISK_LIST[@]}") || err "cancelled"
TARGET_DISK="/dev/$DISK_ID"
[[ $TARGET_DISK == *"nvme"* ]] && P="p" || P=""

if [[ "$TARGET_DISK" == *"nvme"* ]]; then
    DISK_TYPE="nvme"
elif [[ "$(cat /sys/block/$(basename $TARGET_DISK)/queue/rotational 2>/dev/null)" == "0" ]]; then
    DISK_TYPE="ssd"
fi

if [[ "$DISK_TYPE" == "nvme" ]]; then
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="nvme[0-9]*", ATTR{queue/scheduler}="none"'
elif [[ "$DISK_TYPE" == "ssd" ]]; then
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="mq-deadline"'
else
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"'
fi

# get total disk size in GB for slider
TOTAL_DISK_SIZE=$(lsblk -dno SIZE -b /dev/$DISK_ID | awk '{printf "%.0f", $1/1024/1024/1024}')
FREE_DISK_SPACE=$TOTAL_DISK_SIZE

# dual boot / disk split option with slider
header "Disk Option"

disk_option_choice=$(tui_radiolist "Disk Option" "Disk: ${TARGET_DISK} (${TOTAL_DISK_SIZE}GB)\nFree Space: ${FREE_DISK_SPACE}GB\n\nSelect installation method:" \
    "1" "Format entire disk  - erase everything, single OS" ON \
    "2" "Split disk       - dual boot with existing OS" OFF) || err "cancelled"

case "$disk_option_choice" in
    1)
        FORMAT_DISK=true
        SPLIT_DISK=false
        SPLIT_PERCENT=100
        ;;
    2)
        FORMAT_DISK=false
        SPLIT_DISK=true
        # slider for split percentage - show current value, default 50%
        SPLIT_PERCENT=$(whiptail --title "  Disk Split  " --separate-output --radiolist "Disk: ${TARGET_DISK} (${TOTAL_DISK_SIZE}GB)\n\nSelect how much space to allocate to Zerene:\n(Touch Here ↓ to adjust)" 22 72 14 \
            "25" "25%  (~$(( TOTAL_DISK_SIZE/4 ))GB) - minimal Zerene" OFF \
            "30" "30%  (~$(( TOTAL_DISK_SIZE*3/10 ))GB)" OFF \
            "40" "40%  (~$(( TOTAL_DISK_SIZE*2/5 ))GB)" OFF \
            "50" "50%  (~$(( TOTAL_DISK_SIZE/2 ))GB) - equal split" ON \
            "60" "60%  (~$(( TOTAL_DISK_SIZE*3/5 ))GB)" OFF \
            "70" "70%  (~$(( TOTAL_DISK_SIZE*7/10 ))GB)" OFF \
            "75" "75%  (~$(( TOTAL_DISK_SIZE*3/4 ))GB) - keep other OS" OFF \
            3>&1 1>&2 2>&3) || err "cancelled"
        # calculate actual partition sizes
        ZERENE_SIZE_GB=$(( TOTAL_DISK_SIZE * SPLIT_PERCENT / 100 ))
        OTHER_SIZE_GB=$(( TOTAL_DISK_SIZE - ZERENE_SIZE_GB ))
        FREE_DISK_SPACE=$OTHER_SIZE_GB
        ;;
esac

# quick format confirmation for non-split
if [[ "$FORMAT_DISK" == "true" ]]; then
    tui_yesno "Format Disk" "Wipe and format $TARGET_DISK ?\n\nThis will erase ALL data on this disk." \
        && FORMAT_DISK=true || FORMAT_DISK=false
fi

header "Filesystem"

fs_choice=$(tui_menu "Filesystem Format" "Select the filesystem for your root partition:" \
    "1" "btrfs      - snapshots, compression, subvolumes  [recommended]" \
    "2" "ext4       - classic, stable, widely supported" \
    "3" "xfs        - high-performance, good for large files" \
    "4" "f2fs       - flash-friendly, ideal for SSDs/NVMe" \
    "5" "bcachefs   - modern CoW, snapshots, encryption") || err "cancelled"

case "$fs_choice" in
    1) FS_TYPE="btrfs" ;;
    2) FS_TYPE="ext4" ;;
    3) FS_TYPE="xfs" ;;
    4) FS_TYPE="f2fs" ;;
    5) FS_TYPE="bcachefs" ;;
    *) FS_TYPE="btrfs" ;;
esac

header "Nix Package Manager"

nix_choice=$(tui_menu "Nix" "Include Nix package manager?" \
    "1" "Yes - install Nix (multi-user daemon mode)" \
    "2" "No  - skip Nix") || err "cancelled"

header "Timeshift Snapshots"

timeshift_choice=$(tui_menu "Timeshift" "Configure automated system snapshots with Timeshift?\n\nTimeshift will auto-snapshot before every pacman install/upgrade." \
    "1" "Yes - install Timeshift + auto-snapshot on pacman  [recommended]" \
    "2" "No  - skip Timeshift") || err "cancelled"

INSTALL_TIMESHIFT=false
TIMESHIFT_TYPE="rsync"

if [[ "$timeshift_choice" == "1" ]]; then
    INSTALL_TIMESHIFT=true

    # auto-pick snapshot type based on filesystem
    if [[ "$FS_TYPE" == "btrfs" ]]; then
        TIMESHIFT_TYPE="btrfs"
        tui_msg "Timeshift Mode" "Btrfs filesystem detected.\nTimeshift will use BTRFS mode (instant CoW snapshots)."
    else
        TIMESHIFT_TYPE="rsync"
        tui_msg "Timeshift Mode" "Using RSYNC mode (works on ext4, xfs, f2fs, bcachefs).\nSnapshots are stored as full directory copies."
    fi

    timeshift_keep=$(tui_menu "Snapshot Retention" "How many snapshots to keep per trigger type?" \
        "3"  "Keep 3  - lightweight, saves disk space" \
        "5"  "Keep 5  - balanced  [recommended]" \
        "10" "Keep 10 - more history, uses more space") || err "cancelled"

    TIMESHIFT_KEEP="${timeshift_keep:-5}"
fi

header "Kernel"

KERN_PROMPT="  CPU:    $CPU_MODEL_NAME\n  Cores:  $CPU_CORES     RAM: ${RAM_MB} MB\n  Disk:   $DISK_TYPE     Laptop: $IS_LAPTOP\n\nSelect a kernel:"

kernel_choice=$(tui_menu "Kernel" "$KERN_PROMPT" \
    "1" "linux          - stable, default arch kernel" \
    "2" "linux-zen      - lower latency, better for gaming/desktop" \
    "3" "linux-hardened - security hardened" \
    "4" "linux-lts      - long term support, older but very stable" \
    "5" "auto-tune      - zerene picks best kernel + tunes for your hw" \
    "6" "auto-config   - generate .config based on your specs" \
    "7" "advanced       - you configure it (menuconfig / vim / nano)") || err "cancelled"

KERNEL_PKG="linux"
KERNEL_HEADERS="linux-headers"
ADVANCED_KERNEL=false
AUTO_TUNE=false
AUTO_CONFIG=false
KERN_PARAMS=""
AUTO_CONFIG_CONTENT=""

case "$kernel_choice" in
    1) KERNEL_PKG="linux";          KERNEL_HEADERS="linux-headers" ;;
    2) KERNEL_PKG="linux-zen";      KERNEL_HEADERS="linux-zen-headers" ;;
    3) KERNEL_PKG="linux-hardened"; KERNEL_HEADERS="linux-hardened-headers" ;;
    4) KERNEL_PKG="linux-lts";      KERNEL_HEADERS="linux-lts-headers" ;;
    5)
        AUTO_TUNE=true
        if   [[ "$IS_VM" == "true" ]]; then
            KERNEL_PKG="linux";     KERNEL_HEADERS="linux-headers"
        elif [[ "$CPU_VENDOR" == "AuthenticAMD" && "$IS_LAPTOP" == "false" ]]; then
            KERNEL_PKG="linux-zen"; KERNEL_HEADERS="linux-zen-headers"
        else
            KERNEL_PKG="linux";     KERNEL_HEADERS="linux-headers"
        fi
        # amd tuning
        if [[ "$CPU_VENDOR" == "AuthenticAMD" ]]; then
            if [[ "$CPU_FAMILY" -ge 25 ]] || { [[ "$CPU_FAMILY" -eq 23 ]] && [[ "$CPU_MODEL" -ge 49 ]]; }; then
                KERN_PARAMS="$KERN_PARAMS amd_pstate=active"
            fi
            KERN_PARAMS="$KERN_PARAMS processor.max_cstate=5"
            [[ "$IS_VM" == "false" ]] && KERN_PARAMS="$KERN_PARAMS spec_store_bypass_disable=prctl spectre_v2=off"
        fi
        # intel tuning
        [[ "$CPU_VENDOR" == "GenuineIntel" && "$CPU_GEN" -ge 6 ]] && KERN_PARAMS="$KERN_PARAMS intel_pstate=active"
        # laptop extras
        [[ "$IS_LAPTOP" == "true" ]] && KERN_PARAMS="$KERN_PARAMS pcie_aspm=force nmi_watchdog=0"
        [[ "$RAM_MB" -lt 4096 ]] && SWAPPINESS=30 || SWAPPINESS=10
        ;;
    6)
        # auto-config - generate .config based on detected hardware
        AUTO_CONFIG=true
        KERNEL_PKG="linux"; KERNEL_HEADERS="linux-headers"

        # generate .config content based on hardware detection
        AUTO_CONFIG_CONTENT="#
# Zerene auto-generated kernel config based on your hardware (TEST)
# Generated for: $CPU_MODEL_NAME
# RAM: ${RAM_MB}MB | Cores: $CPU_CORES | Disk: $DISK_TYPE
#

# Processor type and features
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_X86=y
CONFIG_MICROCODE=y
CONFIG_MICROCODE_AMD=y
CONFIG_MICROCODE_INTEL=y
"

        # CPU vendor specific
        if [[ "$CPU_VENDOR" == "AuthenticAMD" ]]; then
            AUTO_CONFIG_CONTENT+="
# AMD CPU
CONFIG_AMD=y
CONFIG_AMD_CPUID=y
CONFIG_AMD_NB=y
"
            if [[ "$CPU_FAMILY" -ge 25 ]]; then
                AUTO_CONFIG_CONTENT+="CONFIG_AMD_PSTATE=y
CONFIG_ACPI_CPPC=y
"
            fi
        elif [[ "$CPU_VENDOR" == "GenuineIntel" ]]; then
            AUTO_CONFIG_CONTENT+="
# Intel CPU
CONFIG_INTEL=y
CONFIG_INTEL_TDX=y
"
        fi

        # RAM size based config
        if [[ "$RAM_MB" -gt 16384 ]]; then
            AUTO_CONFIG_CONTENT+="
# Large RAM config (>$RAM_MB MB > 16GB)
CONFIG_NUMA=y
CONFIG_KMEMCG=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP_IOPOL=y
"
        fi
        if [[ "$RAM_MB" -lt 4096 ]]; then
            AUTO_CONFIG_CONTENT+="
# Low RAM config (<4GB) - enable zswap for better performance
CONFIG_ZSWAP=y
CONFIG_ZPOOL=y
"
        fi

        # Disk/storage type
        if [[ "$DISK_TYPE" == "ssd" || "$DISK_TYPE" == "nvme" ]]; then
            AUTO_CONFIG_CONTENT+="
# SSD/NVMe optimizations
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_CORE=y
CONFIG_NVME_MULTIPATH=y
CONFIG_MQ_DEADLINE=y
"
        else
            AUTO_CONFIG_CONTENT+="
# HDD optimizations
CONFIG_BFQ_CGROUP_DEBUG=y
CONFIG_BFQ_GROUP_IOSCHED=y
"
        fi

        # Laptop vs desktop
        if [[ "$IS_LAPTOP" == "true" ]]; then
            AUTO_CONFIG_CONTENT+="
# Laptop config
CONFIG_ACPI=y
CONFIG_ACPI_BATTERY=y
CONFIG_ACPI_THERMAL=y
CONFIG_PM_OPP=y
CONFIG_CPU_FREQ_TIMED=y
CONFIG_IKCONFIG_PROC=y
"
        else
            AUTO_CONFIG_CONTENT+="
# Desktop config
CONFIG_HZ_1000=y
CONFIG_NO_HZ=y
CONFIG_NO_HZ_IDLE=y
"
        fi

        # Virtual machine detection
        if [[ "$IS_VM" == "true" ]]; then
            AUTO_CONFIG_CONTENT+="
# Virtual machine guest
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y
CONFIG_VIRT_DRIVERS=y
"
        fi

        # Compression for btrfs/snapshots
        AUTO_CONFIG_CONTENT+="
# Compression and snapshots
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_RUN_SANITY_TESTS=n
CONFIG_ZSTD=y
CONFIG_LZO=y
CONFIG_LZ4=y
CONFIG_CRYPTO_ZSTD=y
"

        # Common configs
        AUTO_CONFIG_CONTENT+="
# Common features
CONFIG_NET=y
CONFIG_INET=y
CONFIG_INET_UDP_TUNNEL=y
CONFIG_IPV6=y
CONFIG_BRIDGE=y
CONFIG_BONDING=y
CONFIG_TUN=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BLK=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_F2FS_FS=y
CONFIG_XFS_FS=y
CONFIG_VFAT_FS=y

# GPU - video for graphics
CONFIG_MODULES=y
CONFIG_DRM=y
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_I915=y
CONFIG_DRM_NOUVEAU=y

# Audio
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_USB_AUDIO=y

# CPU idle and frequency
CONFIG_CPU_IDLE=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y

# Memory management
CONFIG_MMU=y
CONFIG_GUP=y
CONFIG_KSM=y

# Security
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_CC_STACKPROTECTOR=y
CONFIG_IKCONFIG=y

# Networking security
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_STATE=y

# Performance tuning
CONFIG_PREEMPT=y
CONFIG_PREEMPT_VOLUNTARY=y
"
        ;;
    7)
        ADVANCED_KERNEL=true
        KERNEL_PKG="linux"; KERNEL_HEADERS="linux-headers"
        kconfig_method=$(tui_menu "Kernel Config" "Choose your config method:" \
            "1" "menuconfig - ncurses TUI" \
            "2" "xconfig    - Qt GUI (needs X)" \
            "3" "vim        - edit .config in vim" \
            "4" "nano       - edit .config in nano") || err "cancelled"
        ;;
esac

header "System"

kbd_choice=$(tui_menu "Keyboard Layout" "Select keyboard layout:" \
    "us" "QWERTY  (US)" \
    "fr" "AZERTY  (FR)") || err "cancelled"
LAYOUT="$kbd_choice"

audio_choice=$(tui_menu "Audio" "Select audio system:" \
    "1" "Pipewire   - modern, recommended" \
    "2" "Pulseaudio - classic") || err "cancelled"

header "Desktop Environment"

desktop_choice=$(tui_menu "Desktop Environment" "Select your desktop environment:" \
    "1"  "Hyprland      wayland tiling compositor" \
    "2"  "KDE Plasma    full featured kde desktop" \
    "3"  "XFCE4         lightweight classic desktop" \
    "4"  "GNOME         clean modern desktop" \
    "5"  "Sway          wayland tiling, minimal" \
    "6"  "i3            x11 tiling, very lightweight" \
    "7"  "Cinnamon      traditional, based on gnome" \
    "8"  "MATE          classic gnome 2 fork" \
