# --------------------------------------------------------
# helper: detect free/unpartitioned space on a disk
# returns largest contiguous free region in GB
# --------------------------------------------------------
detect_free_space() {
    local disk="$1"
    local total_gb="$2"

    # Use parted to find free space regions
    local free_regions
    free_regions=$(parted -s "$disk" unit MiB print free 2>/dev/null | \
        awk '/Free Space/{print $3}' | tr -d 'MiB' | sort -rn | head -1)

    if [[ -n "$free_regions" && "$free_regions" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        # convert MiB to GB (floor)
        echo $(( ${free_regions%.*} / 1024 ))
    else
        # fallback: assume entire disk is free
        echo "$total_gb"
    fi
}

# helper: list existing partitions on a disk
list_existing_partitions() {
    local disk="$1"
    parted -s "$disk" unit GiB print 2>/dev/null | \
        awk '/^ [0-9]/{printf "  Part %s: %s  %s  %s\n", $1, $4, $5, $6}'
}

