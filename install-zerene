#!/bin/bash

# zerene os installer - xenovia 1

msg()  { echo -e "\e[1;34m>>> $1\e[0m"; }
warn() { echo -e "\e[1;33m!!! $1\e[0m"; }
err()  { echo -e "\e[1;31mERROR: $1\e[0m"; exit 1; }

clear
fastfetch
echo "| -- zerene os installer -- |"
echo

# check internet first
msg "checking internet connection..."
if ! ping -c 1 google.com &>/dev/null; then
    msg "no internet detected, opening nmtui..."
    nmtui
fi


# user
read -rp "hostname: " hostname
read -rp "username: " username
read -rsp "password: " password
echo

# disk
msg "available disks:"
lsblk -dno NAME,SIZE,MODEL | grep -v "loop"
echo
read -rp "disk to install on (e.g. sda or nvme0n1): " DISK_ID
TARGET_DISK="/dev/$DISK_ID"
[[ $TARGET_DISK == *"nvme"* ]] && P="p" || P=""

read -rp "format $TARGET_DISK? this will wipe it [y/N]: " FORMAT_DISK

# nix
echo
echo "include nix package manager?"
echo "1) yes"
echo "2) no"
echo
read -rp "nix: " nix_choice

# hardware scan - do this before kernel menu so we can show detected hardware
msg "scanning hardware..."
CPU_VENDOR=$(grep -m1 "vendor_id" /proc/cpuinfo | awk '{print $3}')
CPU_MODEL_NAME=$(grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | xargs)
CPU_CORES=$(nproc)
CPU_FAMILY=$(grep -m1 "cpu family" /proc/cpuinfo | awk '{print $4}')
CPU_MODEL=$(grep -m1 "^model[[:space:]]" /proc/cpuinfo | awk '{print $3}')
RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
IS_LAPTOP=false
IS_VM=false
DISK_TYPE="hdd"

[ -d /sys/class/power_supply/BAT0 ] || [ -d /sys/class/power_supply/BAT1 ] && IS_LAPTOP=true
grep -qi "virtualbox\|vmware\|kvm\|qemu\|hyper-v" /sys/class/dmi/id/product_name 2>/dev/null && IS_VM=true

if [[ "$TARGET_DISK" == *"nvme"* ]]; then
    DISK_TYPE="nvme"
elif [[ "$(cat /sys/block/$(basename $TARGET_DISK)/queue/rotational 2>/dev/null)" == "0" ]]; then
    DISK_TYPE="ssd"
fi

CPU_GEN=0
if [[ "$CPU_VENDOR" == "GenuineIntel" ]]; then
    CPU_GEN=$(grep -m1 "model name" /proc/cpuinfo | grep -oP "\d+(?:st|nd|rd|th) Gen" | grep -oP "^\d+" || echo 0)
fi

echo
msg "detected: $CPU_MODEL_NAME | ${CPU_CORES} cores | ${RAM_MB}mb ram | disk: $DISK_TYPE | laptop: $IS_LAPTOP | vm: $IS_VM"
echo

# kernel
echo "kernel:"
echo "1) linux          - stable default arch kernel"
echo "2) linux-zen      - better for gaming and desktop, lower latency"
echo "3) linux-hardened - security focused"
echo "4) auto-tune      - picks best kernel and tunes it for your hardware"
echo "5) advanced       - configure it yourself (menuconfig / vim / nano)"
echo
read -rp "kernel: " kernel_choice

KERNEL_PKG="linux"
KERNEL_HEADERS="linux-headers"
ADVANCED_KERNEL=false
AUTO_TUNE=false
KERN_PARAMS=""
SWAPPINESS=10
RAM_HALF=$(( RAM_MB / 2 ))

# io scheduler rule based on disk type
if [[ "$DISK_TYPE" == "nvme" ]]; then
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="nvme[0-9]*", ATTR{queue/scheduler}="none"'
elif [[ "$DISK_TYPE" == "ssd" ]]; then
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="mq-deadline"'
else
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"'
fi

case "$kernel_choice" in
    1)
        KERNEL_PKG="linux"
        KERNEL_HEADERS="linux-headers"
        ;;
    2)
        KERNEL_PKG="linux-zen"
        KERNEL_HEADERS="linux-zen-headers"
        ;;
    3)
        KERNEL_PKG="linux-hardened"
        KERNEL_HEADERS="linux-hardened-headers"
        ;;
    4)
        AUTO_TUNE=true
        # pick kernel based on hardware
        if [[ "$IS_VM" == "true" ]]; then
            KERNEL_PKG="linux"
            KERNEL_HEADERS="linux-headers"
            msg "vm detected, using vanilla kernel"
        elif [[ "$CPU_VENDOR" == "AuthenticAMD" ]] && [[ "$IS_LAPTOP" == "false" ]]; then
            KERNEL_PKG="linux-zen"
            KERNEL_HEADERS="linux-zen-headers"
            msg "amd desktop detected, picking linux-zen"
        elif [[ "$IS_LAPTOP" == "true" ]]; then
            KERNEL_PKG="linux"
            KERNEL_HEADERS="linux-headers"
            msg "laptop detected, picking vanilla kernel (better battery)"
        else
            KERNEL_PKG="linux"
            KERNEL_HEADERS="linux-headers"
            msg "intel desktop, picking vanilla kernel"
        fi

        # amd tuning
        if [[ "$CPU_VENDOR" == "AuthenticAMD" ]]; then
            if [[ "$CPU_FAMILY" -ge 25 ]] || { [[ "$CPU_FAMILY" -eq 23 ]] && [[ "$CPU_MODEL" -ge 49 ]]; }; then
                KERN_PARAMS="$KERN_PARAMS amd_pstate=active"
                msg "zen2+ detected, enabling amd_pstate=active"
            fi
            KERN_PARAMS="$KERN_PARAMS processor.max_cstate=5"
            if [[ "$IS_VM" == "false" ]]; then
                KERN_PARAMS="$KERN_PARAMS spec_store_bypass_disable=prctl spectre_v2=off"
            fi
        fi

        # intel tuning
        if [[ "$CPU_VENDOR" == "GenuineIntel" ]] && [[ "$CPU_GEN" -ge 6 ]]; then
            KERN_PARAMS="$KERN_PARAMS intel_pstate=active"
            msg "intel gen $CPU_GEN, enabling intel_pstate=active"
        fi

        # laptop power saving
        if [[ "$IS_LAPTOP" == "true" ]]; then
            KERN_PARAMS="$KERN_PARAMS pcie_aspm=force nmi_watchdog=0"
        fi

        [[ "$RAM_MB" -lt 4096 ]] && SWAPPINESS=30 || SWAPPINESS=10
        msg "kernel: $KERNEL_PKG | headers: $KERNEL_HEADERS | params:$KERN_PARAMS"
        ;;
    5)
        ADVANCED_KERNEL=true
        KERNEL_PKG="linux"
        KERNEL_HEADERS="linux-headers"
        echo
        echo "config method:"
        echo "1) menuconfig"
        echo "2) xconfig (needs x)"
        echo "3) vim"
        echo "4) nano"
        echo
        read -rp "method: " kconfig_method
        ;;
esac

# keyboard layout
echo
echo "keyboard layout:"
echo "1) qwerty (us)"
echo "2) azerty (fr)"
echo
read -rp "layout: " kbd_choice
LAYOUT=$([[ "$kbd_choice" == "2" ]] && echo "fr" || echo "us")

# audio
echo
echo "audio:"
echo "1) pipewire"
echo "2) pulseaudio"
echo
read -rp "audio: " audio_choice

# desktop
echo
echo "desktop:"
echo "1) hyprland"
echo "2) kde"
echo "3) xfce4"
echo "4) none"
echo
read -rp "desktop: " desktop_choice

# aur helper
echo
echo "aur helper:"
echo "1) yay"
echo "2) paru"
echo "3) none"
echo
read -rp "aur helper: " aur_helper

# gpu
echo
echo "gpu driver:"
echo "1) nvidia modern  - turing/rtx 20xx, gtx 1650 and newer"
echo "2) nvidia legacy  - pascal gtx 10xx and older (aur)"
echo "3) amd            - mesa + vulkan, rdna/gcn"
echo "4) intel          - integrated graphics"
echo "5) vm / none"
echo
read -rp "gpu: " gpu_choice

# network
echo
echo "network manager:"
echo "1) networkmanager - full featured, has nmtui"
echo "2) iwd            - lightweight, fast, wpa3 (wifi only)"
echo
read -rp "network: " net_choice

NET_PKG="networkmanager"
[[ "$net_choice" == "2" ]] && NET_PKG="iwd dhcpcd"

# --------------------------------------------------------
# summary before we do anything destructive
# --------------------------------------------------------

echo
echo "========================================"
echo " install summary"
echo "========================================"
echo " hostname:  $hostname"
echo " username:  $username"
echo " disk:      $TARGET_DISK"
echo " kernel:    $KERNEL_PKG ($KERNEL_HEADERS)"
echo " auto-tune: $AUTO_TUNE"
echo " layout:    $LAYOUT"
echo " audio:     $audio_choice"
echo " desktop:   $desktop_choice"
echo " gpu:       $gpu_choice"
echo " network:   $net_choice"
echo " nix:       $nix_choice"
echo "========================================"
echo
read -rp "looks good? start install [y/N]: " confirm
[[ ! "$confirm" =~ ^[Yy]$ ]] && err "install cancelled"

# --------------------------------------------------------
# now we actually start doing stuff
# --------------------------------------------------------

swapoff -a

if [[ "$FORMAT_DISK" =~ ^[Yy]$ ]]; then
    msg "partitioning $TARGET_DISK..."
    parted -s "$TARGET_DISK" mklabel gpt
    parted -s "$TARGET_DISK" mkpart ESP fat32 1MiB 513MiB
    parted -s "$TARGET_DISK" set 1 esp on
    parted -s "$TARGET_DISK" mkpart primary ext4 513MiB 100%
    mkfs.fat -F32 "${TARGET_DISK}${P}1"
    mkfs.ext4 "${TARGET_DISK}${P}2"
fi

msg "mounting..."
mount "${TARGET_DISK}${P}2" /mnt
mkdir -p /mnt/boot/efi
mount "${TARGET_DISK}${P}1" /mnt/boot/efi

INSTALL_NIX=false
if [[ "$nix_choice" == "1" ]]; then
    INSTALL_NIX=true
    mkdir -p /mnt/nix/{store,var/nix/db,var/nix/profiles,var/nix/channel-cache}
    chmod -R 1775 /mnt/nix/store
    mkdir -p /mnt/var/empty
fi

msg "installing base system..."
pacstrap /mnt base "$KERNEL_PKG" "$KERNEL_HEADERS" linux-firmware sudo fastfetch plymouth $NET_PKG base-devel dosfstools

# advanced kernel build
if [[ "$ADVANCED_KERNEL" == "true" ]]; then
    msg "setting up kernel build environment..."
    arch-chroot /mnt bash <<KCONF
        pacman -S --noconfirm asp base-devel
        mkdir -p /root/kernelbuild && cd /root/kernelbuild
        asp export linux
        cd linux
        zcat /proc/config.gz > .config 2>/dev/null || \
            cp /usr/lib/modules/\$(uname -r)/build/.config .config 2>/dev/null || \
            make defconfig
        case "$kconfig_method" in
            1) pacman -S --noconfirm ncurses; make menuconfig ;;
            2) pacman -S --noconfirm qt5-base; make xconfig ;;
            3) pacman -S --noconfirm vim; vim .config ;;
            4) pacman -S --noconfirm nano; nano .config ;;
        esac
        read -rp "build and install kernel now? [Y/n]: " build_yn
        if [[ ! "\$build_yn" =~ ^[Nn]$ ]]; then
            make -j\$(nproc)
            make modules_install
            make install
        fi
KCONF
fi

# copy zerene branding
msg "copying zerene assets..."
mkdir -p /mnt/etc/fastfetch
[ -d /etc/fastfetch ] && cp -r /etc/fastfetch/* /mnt/etc/fastfetch/
mkdir -p /mnt/usr/share/pixmaps
cp /usr/share/pixmaps/zerene.svg /mnt/usr/share/pixmaps/ 2>/dev/null || true
mkdir -p /mnt/usr/share/plymouth/themes/
cp -r /usr/share/plymouth/themes/zerene-spinner /mnt/usr/share/plymouth/themes/ 2>/dev/null || true

# --------------------------------------------------------
# chroot - everything from here runs inside the new install
# --------------------------------------------------------

msg "entering chroot..."

arch-chroot /mnt bash <<EOF

echo "$hostname" > /etc/hostname
echo "KEYMAP=$LAYOUT" > /etc/vconsole.conf

mkdir -p /etc/X11/xorg.conf.d
cat > /etc/X11/xorg.conf.d/00-keyboard.conf <<XKEYBOARD
Section "InputClass"
    Identifier "system-keyboard"
    MatchIsKeyboard "on"
    Option "XkbLayout" "$LAYOUT"
EndSection
XKEYBOARD

cat > /etc/os-release <<OS
NAME="Zerene OS"
PRETTY_NAME="Zerene OS (Xenovia 1)"
ID=zerene
ID_LIKE=arch
ANSI_COLOR="38;2;255;50;150"
LOGO=zerene
OS
echo "GRUB_DISTRIBUTOR=\"Zerene OS\"" >> /etc/default/grub

# users and groups
groupadd -r -g 970 nixbld 2>/dev/null || true
groupadd -r nix-users 2>/dev/null || true
for n in \$(seq -w 01 10); do
    useradd -r -u 97\$n -g nixbld -G nixbld -d /var/empty -s /sbin/nologin nixbld\$n 2>/dev/null || true
done
useradd -m -G wheel,video,audio,storage,nix-users -s /bin/bash "$username" 2>/dev/null || true
echo "$username:$password" | chpasswd
echo "root:$password" | chpasswd

if [ ! -f /etc/sudoers ]; then
    touch /etc/sudoers
    chmod 440 /etc/sudoers
fi
if ! grep -q "^%wheel" /etc/sudoers; then
    echo "%wheel ALL=(ALL:ALL) ALL" >> /etc/sudoers
fi
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

# nix
if [[ "$INSTALL_NIX" == "true" ]]; then
    pacman -S --noconfirm nix
    mkdir -p /nix/{store,var/nix/db,var/nix/profiles,var/nix/channel-cache}
    chown -R root:nixbld /nix/store
    chmod 1775 /nix/store
    chown -R root:nixbld /nix/var/nix
    chmod -R ug+rwX /nix/var/nix
    mkdir -p /etc/nix
    cat > /etc/nix/nix.conf <<NIX
experimental-features = nix-command flakes
max-jobs = auto
build-users-group = nixbld
NIX
    systemctl enable nix-daemon
    cat >> /etc/profile <<NIXRC
if [ -e '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh' ]; then
  source '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh'
fi
NIXRC
    nix-channel --add https://nixos.org/channels/nixpkgs-unstable nixpkgs
    nix-channel --update
fi

# fastfetch config
mkdir -p /home/$username/.config/fastfetch
cat > /home/$username/.config/fastfetch/config.jsonc <<FF
{
  "logo": { "source": "/etc/fastfetch/zerene-ascii.txt", "type": "file" },
  "modules": [ "title", "separator", "os", "host", "kernel", "uptime", "packages", "shell", "terminal", "cpu", "gpu", "memory", "break", "colors" ]
}
FF
echo "fastfetch" >> /home/$username/.bashrc
chown -R $username:$username /home/$username

# audio
if [ "$audio_choice" == "1" ]; then
    pacman -S --noconfirm pipewire pipewire-pulse wireplumber
else
    pacman -S --noconfirm pulseaudio
fi

# gpu drivers
# headers are already installed via pacstrap, dkms needs them to build modules
case "$gpu_choice" in
    1)
        # nvidia modern - turing+ use nvidia-open-dkms since driver 590
        pacman -S --noconfirm nvidia-open-dkms nvidia-utils lib32-nvidia-utils \
            nvidia-settings libglvnd lib32-libglvnd opencl-nvidia

        # nvidia modules must be in initramfs or wayland gets a black screen
        sed -i 's/^MODULES=(/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf

        # kms hook conflicts with nvidia early loading, remove it
        sed -i 's/ kms//' /etc/mkinitcpio.conf

        # blacklist nouveau so it doesnt load before nvidia
        echo "blacklist nouveau" > /etc/modprobe.d/blacklist-nouveau.conf
        echo "options nouveau modeset=0" >> /etc/modprobe.d/blacklist-nouveau.conf

        # hook to auto rebuild initramfs when nvidia updates
        mkdir -p /etc/pacman.d/hooks
        cat > /etc/pacman.d/hooks/nvidia.hook <<NVHOOK
[Trigger]
Operation=Install
Operation=Upgrade
Operation=Remove
Type=Package
Target=nvidia-open-dkms

[Action]
Description=Updating initramfs after nvidia update...
When=PostTransaction
Exec=/usr/bin/mkinitcpio -P
NVHOOK
        ;;
    2)
        # nvidia legacy - pascal and older, aur only since driver 590 dropped them
        pacman -S --noconfirm git base-devel
        (
            cd /tmp
            git clone https://aur.archlinux.org/nvidia-580xx-dkms.git
            chown -R "$username:$username" nvidia-580xx-dkms
            cd nvidia-580xx-dkms
            sudo -u "$username" makepkg -si --noconfirm
        )
        pacman -S --noconfirm nvidia-utils lib32-nvidia-utils libglvnd lib32-libglvnd
        sed -i 's/^MODULES=(/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf
        sed -i 's/ kms//' /etc/mkinitcpio.conf
        echo "blacklist nouveau" > /etc/modprobe.d/blacklist-nouveau.conf
        echo "options nouveau modeset=0" >> /etc/modprobe.d/blacklist-nouveau.conf
        ;;
    3)
        # amd - mesa handles everything, vulkan-radeon for vulkan support
        pacman -S --noconfirm mesa lib32-mesa vulkan-radeon lib32-vulkan-radeon \
            xf86-video-amdgpu libva-mesa-driver lib32-libva-mesa-driver \
            vulkan-icd-loader lib32-vulkan-icd-loader
        ;;
    4)
        # intel - mesa + vulkan-intel, intel-media-driver for hardware video decode
        pacman -S --noconfirm mesa lib32-mesa vulkan-intel lib32-vulkan-intel \
            intel-media-driver libva-utils vulkan-icd-loader lib32-vulkan-icd-loader
        ;;
    5)
        pacman -S --noconfirm mesa lib32-mesa
        ;;
esac

# network
case "$net_choice" in
    1)
        systemctl enable NetworkManager
        ;;
    2)
        systemctl enable iwd systemd-resolved dhcpcd
        mkdir -p /etc/iwd
        cat > /etc/iwd/main.conf <<IWDCONF
[General]
EnableNetworkConfiguration=true

[Network]
NameResolvingService=systemd
IWDCONF
        ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
        ;;
esac

# desktop
case $desktop_choice in
    1) pacman -S --noconfirm hyprland kitty greetd greetd-tuigreet; systemctl enable greetd ;;
    2) pacman -S --noconfirm plasma-desktop sddm konsole; systemctl enable sddm ;;
    3) pacman -S --noconfirm xfce4 gvfs lightdm lightdm-gtk-greeter xfce4-terminal; systemctl enable lightdm ;;
esac

# aur helper
case $aur_helper in
    1|2)
        helper=\$([[ "$aur_helper" == "1" ]] && echo "yay" || echo "paru")
        (
            cd /tmp
            git clone "https://aur.archlinux.org/\$helper.git"
            chown -R "$username:$username" "\$helper"
            cd "\$helper"
            sudo -u "$username" makepkg -si --noconfirm
        )
        ;;
esac

# --------------------------------------------------------
# kernel tuning
# --------------------------------------------------------

# base grub params, nvidia drm modeset, and auto-tune extras if picked
GRUB_EXTRAS="quiet splash audit=0"

if [[ "$gpu_choice" == "1" || "$gpu_choice" == "2" ]]; then
    GRUB_EXTRAS="\$GRUB_EXTRAS nvidia_drm.modeset=1"
fi

if [[ "$AUTO_TUNE" == "true" ]]; then
    GRUB_EXTRAS="\$GRUB_EXTRAS $KERN_PARAMS"
fi

sed -i "s|GRUB_CMDLINE_LINUX_DEFAULT=\"|GRUB_CMDLINE_LINUX_DEFAULT=\"\$GRUB_EXTRAS |" /etc/default/grub

# sysctl tweaks
mkdir -p /etc/sysctl.d
cat > /etc/sysctl.d/99-zerene.conf <<SYSCTL
vm.swappiness = $SWAPPINESS
vm.vfs_cache_pressure = 50
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
net.ipv4.tcp_fastopen = 3
net.ipv4.tcp_fin_timeout = 10
net.ipv4.tcp_tw_reuse = 1
fs.inotify.max_user_watches = 524288
SYSCTL

# io scheduler
mkdir -p /etc/udev/rules.d
echo '$IO_SCHED_RULE' > /etc/udev/rules.d/60-io-scheduler.rules

# cpu governor
mkdir -p /etc/tmpfiles.d
if [[ "$IS_LAPTOP" == "true" ]]; then
    echo "w /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor - - - - powersave" \
        > /etc/tmpfiles.d/cpu-governor.conf
else
    echo "w /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor - - - - schedutil" \
        > /etc/tmpfiles.d/cpu-governor.conf
fi

# zram
pacman -S --noconfirm zram-generator
cat > /etc/systemd/zram-generator.conf <<ZRAM
[zram0]
zram-size = ${RAM_HALF}M
compression-algorithm = zstd
ZRAM

# tuning summary
cat > /etc/zerene-tune.txt <<TUNE
zerene auto tuning - applied at install

cpu:        $CPU_MODEL_NAME
cores:      $CPU_CORES
ram:        ${RAM_MB}mb
disk:       $DISK_TYPE
laptop:     $IS_LAPTOP
vm:         $IS_VM
kernel:     $KERNEL_PKG
headers:    $KERNEL_HEADERS
auto-tune:  $AUTO_TUNE

grub extras: \$GRUB_EXTRAS
swappiness:  $SWAPPINESS
io sched:    $DISK_TYPE optimized
zram:        ${RAM_HALF}mb zstd
TUNE

# initramfs and bootloader
sed -i 's/^MODULES=(/MODULES=(vboxvideo /' /etc/mkinitcpio.conf
sed -i 's/HOOKS=(base udev/HOOKS=(base udev plymouth/' /etc/mkinitcpio.conf
mkinitcpio -p "$KERNEL_PKG"

pacman -S --noconfirm grub efibootmgr
grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=Zerene --recheck

mkdir -p /boot/efi/EFI/BOOT
cp /boot/efi/EFI/Zerene/grubx64.efi /boot/efi/EFI/BOOT/BOOTX64.EFI

grub-mkconfig -o /boot/grub/grub.cfg

EOF

msg "unmounting..."
umount -R /mnt 2>/dev/null || true

msg "zerene os installed!"
echo
echo "tuning info saved to /etc/zerene-tune.txt"
echo "you can reboot now"
