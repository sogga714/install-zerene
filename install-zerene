step_identity() {
    local h u p p2 pc
    h=$(tui_input "Hostname" "Enter a hostname for this machine:" "$hostname") || return 1
    hostname="$h"

    u=$(tui_input "User Account" "Enter your username:" "$username") || return 1
    username="$u"

    p=$(tui_pass "User Account" "Enter password for '$username':") || return 1
    p2=$(tui_pass "User Account" "Confirm password:") || return 1
    if [[ "$p" != "$p2" ]]; then
        tui_msg "Password Mismatch" "The passwords you entered do not match.\nPlease try again."
        step_identity
        return $?
    fi
    password="$p"

    pc=$(tui_menu "Privilege Escalation" "Select your privilege escalation tool:" \
        "1" "sudo      - standard, most compatible (recommended)" \
        "2" "doas      - minimal, openbsd-style (opendoas)") || return 1
    priv_choice="$pc"
}

step_timezone() {
    # build region list from /usr/share/zoneinfo
    local REGIONS=()
    local region
    while IFS= read -r region; do
        REGIONS+=("$region" "")
    done < <(ls /usr/share/zoneinfo/ | grep -v '[+\-]' | \
        while read f; do [ -d "/usr/share/zoneinfo/$f" ] && echo "$f"; done | sort)

    local selected_region
    selected_region=$(tui_menu "Timezone - Region" "Select your region:" "${REGIONS[@]}") || return 1

    # build zone list for that region
    local ZONES=()
    local zone
    while IFS= read -r zone; do
        ZONES+=("$zone" "")
    done < <(ls "/usr/share/zoneinfo/$selected_region" 2>/dev/null | sort)

    if [[ ${#ZONES[@]} -eq 0 ]]; then
        # region IS the zone (e.g. UTC)
        TIMEZONE="$selected_region"
        return 0
    fi

    local selected_zone
    selected_zone=$(tui_menu "Timezone - Zone" "Region: $selected_region\n\nSelect your timezone:" "${ZONES[@]}") || {
        # back from zone list goes back to region selection
        step_timezone
        return $?
    }
    TIMEZONE="$selected_region/$selected_zone"
}

