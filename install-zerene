#!/bin/bash

# zerene os installer - xenovia 1

# --------------------------------------------------------
# colors and helpers
# --------------------------------------------------------

RED='\033[0;31m'
PINK='\033[38;2;255;50;150m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
DIM='\033[2m'
RESET='\033[0m'
BOLD='\033[1m'

msg()  { echo -e "${PINK}>>>${RESET} $1"; }
warn() { echo -e "${RED}!!!${RESET} $1"; }
err()  { echo -e "${RED}ERROR:${RESET} $1"; exit 1; }

# --------------------------------------------------------
# spinning turbine animation
# shows while something heavy is running in the background
# usage: spin_start; do_something; spin_stop
# --------------------------------------------------------

SPIN_PID=""

spin_start() {
    local label="${1:-working...}"
    # turbine blade frames - rotates like a fan/turbine
    local frames=('◢◤' '◥◣' '◤◢' '◣◥')
    local blades=('⣾' '⣽' '⣻' '⢿' '⡿' '⣟' '⣯' '⣷')
    (
        local i=0
        local b=0
        while true; do
            local blade="${blades[$b]}"
            local frame="${frames[$i]}"
            printf "\r${PINK}  %s ${WHITE}%s${RESET}  ${DIM}%s${RESET}   " \
                "$blade" "$frame" "$label"
            sleep 0.08
            i=$(( (i + 1) % 4 ))
            b=$(( (b + 1) % 8 ))
        done
    ) &
    SPIN_PID=$!
}

spin_stop() {
    if [[ -n "$SPIN_PID" ]]; then
        kill "$SPIN_PID" 2>/dev/null
        wait "$SPIN_PID" 2>/dev/null
        SPIN_PID=""
        printf "\r%-60s\r" " "
    fi
}

# make sure spinner dies if script exits unexpectedly
trap spin_stop EXIT

# --------------------------------------------------------
# whiptail helper wrappers so menus are less verbose
# --------------------------------------------------------

# single choice menu - returns selected tag
tui_menu() {
    local title="$1"
    local prompt="$2"
    shift 2
    whiptail --title "$title" --menu "$prompt" 20 70 12 "$@" 3>&1 1>&2 2>&3
}

# yes/no box - returns 0 for yes, 1 for no
tui_yesno() {
    local title="$1"
    local prompt="$2"
    whiptail --title "$title" --yesno "$prompt" 10 60
}

# input box - returns typed value
tui_input() {
    local title="$1"
    local prompt="$2"
    local default="${3:-}"
    whiptail --title "$title" --inputbox "$prompt" 10 60 "$default" 3>&1 1>&2 2>&3
}

# password box
tui_pass() {
    local title="$1"
    local prompt="$2"
    whiptail --title "$title" --passwordbox "$prompt" 10 60 3>&1 1>&2 2>&3
}

# info/message box (no input)
tui_msg() {
    local title="$1"
    local prompt="$2"
    whiptail --title "$title" --msgbox "$prompt" 12 65
}

# --------------------------------------------------------
# splash screen with turbine
# --------------------------------------------------------

clear
echo
echo -e "${PINK}"
cat << 'LOGO'
  ███████╗███████╗██████╗ ███████╗███╗   ██╗███████╗
  ╚══███╔╝██╔════╝██╔══██╗██╔════╝████╗  ██║██╔════╝
    ███╔╝ █████╗  ██████╔╝█████╗  ██╔██╗ ██║█████╗
   ███╔╝  ██╔══╝  ██╔══██╗██╔══╝  ██║╚██╗██║██╔══╝
  ███████╗███████╗██║  ██║███████╗██║ ╚████║███████╗
  ╚══════╝╚══════╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═══╝╚══════╝
LOGO
echo -e "${RESET}"
echo -e "${DIM}          xenovia 1 installer${RESET}"
echo

# check whiptail is available
if ! command -v whiptail &>/dev/null; then
    msg "installing whiptail..."
    pacman -S --noconfirm libnewt
fi

# check internet
msg "checking internet connection..."
if ! ping -c 1 -W 3 google.com &>/dev/null; then
    tui_msg "No Internet" "No internet detected.\n\nThe installer will open nmtui so you can connect.\nCome back and re-run the installer after connecting."
    nmtui
    ping -c 1 -W 3 google.com &>/dev/null || err "still no internet, exiting"
fi

msg "connected"
echo

# --------------------------------------------------------
# hardware scan up front - used in kernel menu
# --------------------------------------------------------

spin_start "scanning hardware"
CPU_VENDOR=$(grep -m1 "vendor_id" /proc/cpuinfo | awk '{print $3}')
CPU_MODEL_NAME=$(grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | xargs)
CPU_CORES=$(nproc)
CPU_FAMILY=$(grep -m1 "cpu family" /proc/cpuinfo | awk '{print $4}')
CPU_MODEL=$(grep -m1 "^model[[:space:]]" /proc/cpuinfo | awk '{print $3}')
RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
IS_LAPTOP=false
IS_VM=false
DISK_TYPE="hdd"

[ -d /sys/class/power_supply/BAT0 ] || [ -d /sys/class/power_supply/BAT1 ] && IS_LAPTOP=true
grep -qi "virtualbox\|vmware\|kvm\|qemu\|hyper-v" /sys/class/dmi/id/product_name 2>/dev/null && IS_VM=true

CPU_GEN=0
if [[ "$CPU_VENDOR" == "GenuineIntel" ]]; then
    CPU_GEN=$(grep -m1 "model name" /proc/cpuinfo | grep -oP "\d+(?:st|nd|rd|th) Gen" | grep -oP "^\d+" || echo 0)
fi

RAM_HALF=$(( RAM_MB / 2 ))
SWAPPINESS=10
spin_stop

# --------------------------------------------------------
# all questions up front
# --------------------------------------------------------

# identity
hostname=$(tui_input "Zerene OS Installer" "Enter hostname:" "zerene") || err "cancelled"
username=$(tui_input "Zerene OS Installer" "Enter username:") || err "cancelled"
password=$(tui_pass "Zerene OS Installer" "Enter password:") || err "cancelled"
password2=$(tui_pass "Zerene OS Installer" "Confirm password:") || err "cancelled"
[[ "$password" != "$password2" ]] && err "passwords do not match"

# disk
DISK_LIST=()
while IFS= read -r line; do
    name=$(echo "$line" | awk '{print $1}')
    size=$(echo "$line" | awk '{print $2}')
    model=$(echo "$line" | awk '{$1=$2=""; print $0}' | xargs)
    DISK_LIST+=("$name" "$size - $model")
done < <(lsblk -dno NAME,SIZE,MODEL | grep -v "loop")

DISK_ID=$(tui_menu "Disk Selection" "Select disk to install on:" "${DISK_LIST[@]}") || err "cancelled"
TARGET_DISK="/dev/$DISK_ID"
[[ $TARGET_DISK == *"nvme"* ]] && P="p" || P=""

# detect disk type now that we have it
if [[ "$TARGET_DISK" == *"nvme"* ]]; then
    DISK_TYPE="nvme"
elif [[ "$(cat /sys/block/$(basename $TARGET_DISK)/queue/rotational 2>/dev/null)" == "0" ]]; then
    DISK_TYPE="ssd"
fi

# io scheduler based on disk type
if [[ "$DISK_TYPE" == "nvme" ]]; then
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="nvme[0-9]*", ATTR{queue/scheduler}="none"'
elif [[ "$DISK_TYPE" == "ssd" ]]; then
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="mq-deadline"'
else
    IO_SCHED_RULE='ACTION=="add|change", KERNEL=="sd[a-z]", ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"'
fi

tui_yesno "Format Disk" "Format $TARGET_DISK?\n\nThis will WIPE everything on the disk." && FORMAT_DISK=true || FORMAT_DISK=false

# nix
nix_choice=$(tui_menu "Nix Package Manager" "Include Nix?" \
    "1" "Yes - install Nix multi-user daemon" \
    "2" "No  - skip Nix") || err "cancelled"

# kernel - show detected hardware in the prompt
KERN_PROMPT="Detected: $CPU_MODEL_NAME\nCores: $CPU_CORES  RAM: ${RAM_MB}MB  Disk: $DISK_TYPE  Laptop: $IS_LAPTOP\n\nSelect kernel:"

kernel_choice=$(tui_menu "Kernel Selection" "$KERN_PROMPT" \
    "1" "linux          - stable default arch kernel" \
    "2" "linux-zen      - better for gaming, lower latency" \
    "3" "linux-hardened - security focused" \
    "4" "auto-tune      - picks best kernel and tunes for your hardware" \
    "5" "advanced       - configure it yourself (menuconfig/vim/nano)") || err "cancelled"

KERNEL_PKG="linux"
KERNEL_HEADERS="linux-headers"
ADVANCED_KERNEL=false
AUTO_TUNE=false
KERN_PARAMS=""

case "$kernel_choice" in
    1) KERNEL_PKG="linux";          KERNEL_HEADERS="linux-headers" ;;
    2) KERNEL_PKG="linux-zen";      KERNEL_HEADERS="linux-zen-headers" ;;
    3) KERNEL_PKG="linux-hardened"; KERNEL_HEADERS="linux-hardened-headers" ;;
    4)
        AUTO_TUNE=true
        if [[ "$IS_VM" == "true" ]]; then
            KERNEL_PKG="linux"; KERNEL_HEADERS="linux-headers"
        elif [[ "$CPU_VENDOR" == "AuthenticAMD" ]] && [[ "$IS_LAPTOP" == "false" ]]; then
            KERNEL_PKG="linux-zen"; KERNEL_HEADERS="linux-zen-headers"
        else
            KERNEL_PKG="linux"; KERNEL_HEADERS="linux-headers"
        fi

        if [[ "$CPU_VENDOR" == "AuthenticAMD" ]]; then
            if [[ "$CPU_FAMILY" -ge 25 ]] || { [[ "$CPU_FAMILY" -eq 23 ]] && [[ "$CPU_MODEL" -ge 49 ]]; }; then
                KERN_PARAMS="$KERN_PARAMS amd_pstate=active"
            fi
            KERN_PARAMS="$KERN_PARAMS processor.max_cstate=5"
            [[ "$IS_VM" == "false" ]] && KERN_PARAMS="$KERN_PARAMS spec_store_bypass_disable=prctl spectre_v2=off"
        fi
        if [[ "$CPU_VENDOR" == "GenuineIntel" ]] && [[ "$CPU_GEN" -ge 6 ]]; then
            KERN_PARAMS="$KERN_PARAMS intel_pstate=active"
        fi
        [[ "$IS_LAPTOP" == "true" ]] && KERN_PARAMS="$KERN_PARAMS pcie_aspm=force nmi_watchdog=0"
        [[ "$RAM_MB" -lt 4096 ]] && SWAPPINESS=30 || SWAPPINESS=10
        ;;
    5)
        ADVANCED_KERNEL=true
        KERNEL_PKG="linux"; KERNEL_HEADERS="linux-headers"
        kconfig_method=$(tui_menu "Kernel Config Method" "How do you want to configure the kernel?" \
            "1" "menuconfig - ncurses TUI" \
            "2" "xconfig    - Qt GUI (needs X)" \
            "3" "vim        - edit .config in vim" \
            "4" "nano       - edit .config in nano") || err "cancelled"
        ;;
esac

# keyboard layout
kbd_choice=$(tui_menu "Keyboard Layout" "Select keyboard layout:" \
    "us" "QWERTY (US)" \
    "fr" "AZERTY (FR)") || err "cancelled"
LAYOUT="$kbd_choice"

# audio
audio_choice=$(tui_menu "Audio" "Select audio system:" \
    "1" "Pipewire   - modern, recommended" \
    "2" "Pulseaudio - classic") || err "cancelled"

# desktop
desktop_choice=$(tui_menu "Desktop Environment" "Select desktop environment:" \
    "1"  "Hyprland   - wayland tiling compositor" \
    "2"  "KDE Plasma - full featured kde desktop" \
    "3"  "XFCE4      - lightweight classic desktop" \
    "4"  "GNOME      - clean modern desktop" \
    "5"  "Sway       - wayland tiling, minimal" \
    "6"  "i3         - x11 tiling, very lightweight" \
    "7"  "Cinnamon   - traditional, based on gnome" \
    "8"  "MATE       - classic gnome 2 fork" \
    "9"  "LXQt       - super lightweight qt desktop" \
    "10" "Budgie     - clean and simple" \
    "11" "Deepin     - polished chinese desktop" \
    "12" "Openbox    - bare window manager only" \
    "13" "bspwm      - tiling wm, scriptable" \
    "14" "Qtile      - python tiling wm" \
    "15" "COSMIC     - new rust desktop from system76" \
    "16" "None       - no desktop") || err "cancelled"

# aur helper
aur_helper=$(tui_menu "AUR Helper" "Select AUR helper:" \
    "1" "yay  - go based, popular" \
    "2" "paru - rust based, faster" \
    "3" "none - skip") || err "cancelled"

# gpu
gpu_choice=$(tui_menu "GPU Driver" "Select GPU driver:" \
    "1" "NVIDIA Modern  - RTX/Turing, GTX 1650 and newer" \
    "2" "NVIDIA Legacy  - Pascal GTX 10xx and older (AUR)" \
    "3" "AMD            - mesa + vulkan, RDNA/GCN" \
    "4" "Intel          - integrated graphics" \
    "5" "VM / None      - virtual machine or skip") || err "cancelled"

# network
net_choice=$(tui_menu "Network Manager" "Select network manager:" \
    "1" "NetworkManager - full featured, has nmtui" \
    "2" "iwd (iwctl)    - lightweight, fast, WPA3") || err "cancelled"

NET_PKG="networkmanager"
[[ "$net_choice" == "2" ]] && NET_PKG="iwd dhcpcd"

# readable names for summary
case $desktop_choice in
    1) DESKTOP_NAME="Hyprland" ;;   2) DESKTOP_NAME="KDE Plasma" ;;
    3) DESKTOP_NAME="XFCE4" ;;      4) DESKTOP_NAME="GNOME" ;;
    5) DESKTOP_NAME="Sway" ;;        6) DESKTOP_NAME="i3" ;;
    7) DESKTOP_NAME="Cinnamon" ;;   8) DESKTOP_NAME="MATE" ;;
    9) DESKTOP_NAME="LXQt" ;;       10) DESKTOP_NAME="Budgie" ;;
    11) DESKTOP_NAME="Deepin" ;;    12) DESKTOP_NAME="Openbox" ;;
    13) DESKTOP_NAME="bspwm" ;;     14) DESKTOP_NAME="Qtile" ;;
    15) DESKTOP_NAME="COSMIC" ;;    16) DESKTOP_NAME="None" ;;
    *) DESKTOP_NAME="None" ;;
esac
case $aur_helper in 1) AUR_NAME="yay" ;; 2) AUR_NAME="paru" ;; *) AUR_NAME="none" ;; esac
case $gpu_choice in
    1) GPU_NAME="NVIDIA Modern" ;; 2) GPU_NAME="NVIDIA Legacy" ;;
    3) GPU_NAME="AMD" ;;           4) GPU_NAME="Intel" ;;
    5) GPU_NAME="VM/None" ;;
esac
case $net_choice in 1) NET_NAME="NetworkManager" ;; 2) NET_NAME="iwd" ;; esac
case $nix_choice in 1) NIX_NAME="yes" ;; *) NIX_NAME="no" ;; esac
case $audio_choice in 1) AUDIO_NAME="Pipewire" ;; 2) AUDIO_NAME="Pulseaudio" ;; esac

# --------------------------------------------------------
# summary confirmation
# --------------------------------------------------------

SUMMARY="Review your install choices:

  Hostname:   $hostname
  Username:   $username
  Disk:       $TARGET_DISK  (format: $FORMAT_DISK)
  Kernel:     $KERNEL_PKG  ($KERNEL_HEADERS)
  Auto-tune:  $AUTO_TUNE
  Layout:     $LAYOUT
  Audio:      $AUDIO_NAME
  Desktop:    $DESKTOP_NAME
  AUR Helper: $AUR_NAME
  GPU:        $GPU_NAME
  Network:    $NET_NAME
  Nix:        $NIX_NAME

Proceed with installation?"

tui_yesno "Install Summary" "$SUMMARY" || err "install cancelled by user"

# --------------------------------------------------------
# install starts here - nothing destructive happened before this
# --------------------------------------------------------

clear
echo
echo -e "${PINK}  starting zerene os installation...${RESET}"
echo

# partition and format
if [[ "$FORMAT_DISK" == "true" ]]; then
    spin_start "partitioning $TARGET_DISK"
    swapoff -a
    parted -s "$TARGET_DISK" mklabel gpt
    parted -s "$TARGET_DISK" mkpart ESP fat32 1MiB 513MiB
    parted -s "$TARGET_DISK" set 1 esp on
    parted -s "$TARGET_DISK" mkpart primary ext4 513MiB 100%
    mkfs.fat -F32 "${TARGET_DISK}${P}1" &>/dev/null
    mkfs.ext4 -F "${TARGET_DISK}${P}2" &>/dev/null
    spin_stop
    msg "disk partitioned"
fi

spin_start "mounting filesystems"
mount "${TARGET_DISK}${P}2" /mnt
mkdir -p /mnt/boot/efi
mount "${TARGET_DISK}${P}1" /mnt/boot/efi
spin_stop
msg "mounted"

INSTALL_NIX=false
if [[ "$nix_choice" == "1" ]]; then
    INSTALL_NIX=true
    mkdir -p /mnt/nix/{store,var/nix/db,var/nix/profiles,var/nix/channel-cache}
    chmod -R 1775 /mnt/nix/store
    mkdir -p /mnt/var/empty
fi

spin_start "installing base system (this takes a while)"
pacstrap /mnt base "$KERNEL_PKG" "$KERNEL_HEADERS" linux-firmware \
    sudo fastfetch plymouth $NET_PKG base-devel dosfstools git &>/dev/null
spin_stop
msg "base system installed"

# advanced kernel build
if [[ "$ADVANCED_KERNEL" == "true" ]]; then
    msg "setting up kernel build environment..."
    arch-chroot /mnt bash <<KCONF
        pacman -S --noconfirm asp base-devel
        mkdir -p /root/kernelbuild && cd /root/kernelbuild
        asp export linux
        cd linux
        zcat /proc/config.gz > .config 2>/dev/null || \
            cp /usr/lib/modules/\$(uname -r)/build/.config .config 2>/dev/null || \
            make defconfig
        case "$kconfig_method" in
            1) pacman -S --noconfirm ncurses; make menuconfig ;;
            2) pacman -S --noconfirm qt5-base; make xconfig ;;
            3) pacman -S --noconfirm vim; vim .config ;;
            4) pacman -S --noconfirm nano; nano .config ;;
        esac
        read -rp "build and install kernel now? [Y/n]: " build_yn
        if [[ ! "\$build_yn" =~ ^[Nn]$ ]]; then
            make -j\$(nproc)
            make modules_install
            make install
        fi
KCONF
fi

# copy zerene branding
spin_start "copying zerene assets"
mkdir -p /mnt/etc/fastfetch
[ -d /etc/fastfetch ] && cp -r /etc/fastfetch/* /mnt/etc/fastfetch/
mkdir -p /mnt/usr/share/pixmaps
cp /usr/share/pixmaps/zerene.svg /mnt/usr/share/pixmaps/ 2>/dev/null || true
mkdir -p /mnt/usr/share/plymouth/themes/
cp -r /usr/share/plymouth/themes/zerene-spinner /mnt/usr/share/plymouth/themes/ 2>/dev/null || true
spin_stop

# --------------------------------------------------------
# chroot
# --------------------------------------------------------

msg "entering chroot..."

arch-chroot /mnt bash <<EOF

echo "$hostname" > /etc/hostname
echo "KEYMAP=$LAYOUT" > /etc/vconsole.conf

mkdir -p /etc/X11/xorg.conf.d
cat > /etc/X11/xorg.conf.d/00-keyboard.conf <<XKEYBOARD
Section "InputClass"
    Identifier "system-keyboard"
    MatchIsKeyboard "on"
    Option "XkbLayout" "$LAYOUT"
EndSection
XKEYBOARD

cat > /etc/os-release <<OS
NAME="Zerene OS"
PRETTY_NAME="Zerene OS (Xenovia 1)"
ID=zerene
ID_LIKE=arch
ANSI_COLOR="38;2;255;50;150"
LOGO=zerene
OS
echo "GRUB_DISTRIBUTOR=\"Zerene OS\"" >> /etc/default/grub

# users
groupadd -r -g 970 nixbld 2>/dev/null || true
groupadd -r nix-users 2>/dev/null || true
for n in \$(seq -w 01 10); do
    useradd -r -u 97\$n -g nixbld -G nixbld -d /var/empty -s /sbin/nologin nixbld\$n 2>/dev/null || true
done
useradd -m -G wheel,video,audio,storage,nix-users -s /bin/bash "$username" 2>/dev/null || true
echo "$username:$password" | chpasswd
echo "root:$password" | chpasswd

if [ ! -f /etc/sudoers ]; then
    touch /etc/sudoers
    chmod 440 /etc/sudoers
fi
if ! grep -q "^%wheel" /etc/sudoers; then
    echo "%wheel ALL=(ALL:ALL) ALL" >> /etc/sudoers
fi
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

# nix
if [[ "$INSTALL_NIX" == "true" ]]; then
    pacman -S --noconfirm nix
    mkdir -p /nix/{store,var/nix/db,var/nix/profiles,var/nix/channel-cache}
    chown -R root:nixbld /nix/store
    chmod 1775 /nix/store
    chown -R root:nixbld /nix/var/nix
    chmod -R ug+rwX /nix/var/nix
    mkdir -p /etc/nix
    cat > /etc/nix/nix.conf <<NIX
experimental-features = nix-command flakes
max-jobs = auto
build-users-group = nixbld
NIX
    systemctl enable nix-daemon
    cat >> /etc/profile <<NIXRC
if [ -e '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh' ]; then
  source '/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh'
fi
NIXRC
    nix-channel --add https://nixos.org/channels/nixpkgs-unstable nixpkgs
    nix-channel --update
fi

# fastfetch config
mkdir -p /home/$username/.config/fastfetch
cat > /home/$username/.config/fastfetch/config.jsonc <<FF
{
  "logo": { "source": "/etc/fastfetch/zerene-ascii.txt", "type": "file" },
  "modules": [ "title", "separator", "os", "host", "kernel", "uptime", "packages", "shell", "terminal", "cpu", "gpu", "memory", "break", "colors" ]
}
FF
echo "fastfetch" >> /home/$username/.bashrc
chown -R $username:$username /home/$username

# audio
if [ "$audio_choice" == "1" ]; then
    pacman -S --noconfirm pipewire pipewire-pulse wireplumber
else
    pacman -S --noconfirm pulseaudio
fi

# gpu drivers
# headers already installed via pacstrap so dkms can build immediately
case "$gpu_choice" in
    1)
        # nvidia modern - turing/rtx 20xx and newer (gtx 1650+)
        # install nvidia-dkms, utils and settings
        pacman -S --noconfirm nvidia-dkms nvidia-utils nvidia-settings \
            lib32-nvidia-utils libglvnd lib32-libglvnd opencl-nvidia

        # run dkms to build the module for the installed kernel
        dkms autoinstall

        # rebuild initramfs so it loads the nvidia modules properly
        mkinitcpio -P

        # add nvidia modules to initramfs
        sed -i 's/^MODULES=(/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf

        # remove kms hook - conflicts with nvidia early loading and causes black screens
        sed -i 's/ kms//' /etc/mkinitcpio.conf

        # blacklist nouveau so it doesnt load before nvidia on boot
        echo "blacklist nouveau" > /etc/modprobe.d/blacklist-nouveau.conf
        echo "options nouveau modeset=0" >> /etc/modprobe.d/blacklist-nouveau.conf

        # pacman hook - rebuilds initramfs automatically when nvidia-dkms updates
        mkdir -p /etc/pacman.d/hooks
        cat > /etc/pacman.d/hooks/nvidia.hook <<NVHOOK
[Trigger]
Operation=Install
Operation=Upgrade
Operation=Remove
Type=Package
Target=nvidia-dkms

[Action]
Description=Updating initramfs after nvidia update...
When=PostTransaction
Exec=/usr/bin/mkinitcpio -P
NVHOOK
        ;;
    2)
        # nvidia legacy - pascal gtx 10xx and older, dropped from main driver 590
        pacman -S --noconfirm git base-devel
        (
            cd /tmp
            git clone https://aur.archlinux.org/nvidia-580xx-dkms.git
            chown -R "$username:$username" nvidia-580xx-dkms
            cd nvidia-580xx-dkms
            sudo -u "$username" makepkg -si --noconfirm
        )
        pacman -S --noconfirm nvidia-utils lib32-nvidia-utils libglvnd lib32-libglvnd
        dkms autoinstall
        mkinitcpio -P
        sed -i 's/^MODULES=(/MODULES=(nvidia nvidia_modeset nvidia_uvm nvidia_drm /' /etc/mkinitcpio.conf
        sed -i 's/ kms//' /etc/mkinitcpio.conf
        echo "blacklist nouveau" > /etc/modprobe.d/blacklist-nouveau.conf
        echo "options nouveau modeset=0" >> /etc/modprobe.d/blacklist-nouveau.conf
        ;;
    3)
        # amd - mesa handles everything, vulkan-radeon for vulkan
        pacman -S --noconfirm mesa lib32-mesa vulkan-radeon lib32-vulkan-radeon \
            xf86-video-amdgpu libva-mesa-driver lib32-libva-mesa-driver \
            vulkan-icd-loader lib32-vulkan-icd-loader
        ;;
    4)
        # intel - mesa + vulkan-intel, intel-media-driver for video decode
        pacman -S --noconfirm mesa lib32-mesa vulkan-intel lib32-vulkan-intel \
            intel-media-driver libva-utils vulkan-icd-loader lib32-vulkan-icd-loader
        ;;
    5)
        pacman -S --noconfirm mesa lib32-mesa
        ;;
esac

# network
case "$net_choice" in
    1) systemctl enable NetworkManager ;;
    2)
        systemctl enable iwd systemd-resolved dhcpcd
