#!/bin/bash
# zerene-snapshot  -  take a labeled on-demand timeshift snapshot
# called by the pacman pre-transaction hook before every install/upgrade/remove
LABEL="${1:-manual}"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
LOG=/var/log/zerene-snapshots.log

echo "[$TIMESTAMP] snapshot requested: $LABEL" >> "$LOG"

if /usr/bin/timeshift --create --scripted --comments "zerene: $LABEL" --tags O >> "$LOG" 2>&1; then
    echo "[$TIMESTAMP] snapshot OK: $LABEL" >> "$LOG"
else
    echo "[$TIMESTAMP] snapshot FAILED: $LABEL" >> "$LOG"
fi
